// Shared 24-swatch palette used by `CutlassColorSwatch` and
// `CutlassColorPicker`. Single source of truth for the curated title /
// accent colors CapCut-style surfaces.

export global ColorPalette {
    // Eight columns; rows of curated colors (neutrals, then hues).
    out property <[[color]]> swatches: [
        [#ffffff, #e0e0e0, #b0b0b0, #808080, #505050, #303030, #1a1a1a, #000000],
        [#ff3b3b, #ff7a3b, #ffb03b, #ffe23b, #b6ff3b, #3bff6e, #3bffd6, #3bb0ff],
        [#3b6eff, #6e3bff, #b03bff, #ff3bd6, #ff3b8a, #8b6d4b, #4b6d8b, #f5f5f5],
    ];
}
