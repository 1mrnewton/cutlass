// Color well that opens the full `CutlassColorPicker` in a popup.
// `changed` is the COMMIT signal (existing consumers keep working);
// optional `preview` fires continuously while interacting; `cancelled`
// fires when the popup closes without a commit for the open gesture
// (click-away mid-drag) so callers can clear live overrides.
//
// Eyedropper: the picker button closes this popup and arms
// `EyedropperStore`; hover/commit/cancel epochs route back through this
// well's preview/changed/cancelled lanes so every consumer keeps working
// without per-call-site wiring.

import { AppStore } from "../store/app-store.slint";
import { AppState } from "../state.slint";
import { EyedropperStore } from "../store/eyedropper-store.slint";
import { ColorUtil } from "../lib/color-util.slint";
import { CutlassColorPicker } from "color-picker.slint";
import { ColorCheckerboard } from "color-picker-parts.slint";

export component CutlassColorSwatch inherits Rectangle {
    in-out property <color> value: #ffffff;
    in property <bool> enabled: true;
    // When false, the picker hides the alpha strip / A channel (opaque models).
    in property <bool> enable-alpha: true;
    // Defaults to the app-wide recent list; empty hides the Recent row.
    in property <[color]> recent-colors: AppStore.recent-colors;

    callback changed(value: color);
    callback preview(value: color);
    callback cancelled();

    function commit-color(c: color) {
        root.gesturing = false;
        root.live = c;
        ColorUtil.record-recent(c);
        root.changed(c);
    }

    width: 104px;
    height: 28px;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: #ffffff10;
    opacity: enabled ? 1.0 : 0.45;

    // Live well fill while the popup is open (model `value` catches up on commit).
    private property <color> live: root.value;
    private property <bool> popup-open: popup.is-open;
    // True after a preview tick until the matching commit or cancel.
    private property <bool> gesturing: false;
    // Close-for-eyedropper: skip the popup's cancel path, then arm.
    private property <bool> arming-eyedropper: false;
    // Token of the session this well armed (0 = not ours).
    private property <int> my-token: 0;

    private property <int> eyedropper-preview-watch: EyedropperStore.preview-epoch;
    private property <int> eyedropper-commit-watch: EyedropperStore.commit-epoch;
    private property <int> eyedropper-cancel-watch: EyedropperStore.cancel-epoch;

    changed value => {
        if (!root.popup-open && root.my-token == 0) {
            root.live = root.value;
        }
    }

    changed popup-open => {
        if (!root.popup-open) {
            if (root.arming-eyedropper) {
                root.arming-eyedropper = false;
                root.gesturing = false;
                root.live = root.value;
                EyedropperStore.consumer-token += 1;
                root.my-token = EyedropperStore.consumer-token;
                EyedropperStore.enable-alpha = root.enable-alpha;
                EyedropperStore.over-frame = false;
                EyedropperStore.label = "";
                EyedropperStore.armed = true;
                AppState.refocus-shortcuts();
                return;
            }
            if (root.gesturing) {
                root.gesturing = false;
                root.live = root.value;
                root.cancelled();
            }
            AppState.refocus-shortcuts();
        }
    }

    changed eyedropper-preview-watch => {
        if (root.my-token != 0
            && EyedropperStore.consumer-token == root.my-token
            && EyedropperStore.over-frame) {
            root.gesturing = true;
            root.live = EyedropperStore.hover-color;
            root.preview(EyedropperStore.hover-color);
        }
    }

    changed eyedropper-commit-watch => {
        if (root.my-token != 0 && EyedropperStore.consumer-token == root.my-token) {
            root.my-token = 0;
            root.commit-color(EyedropperStore.commit-color);
        }
    }

    changed eyedropper-cancel-watch => {
        if (root.my-token != 0 && EyedropperStore.consumer-token == root.my-token) {
            let was = root.gesturing;
            root.gesturing = false;
            root.live = root.value;
            root.my-token = 0;
            if (was) {
                root.cancelled();
            }
        }
    }

    // Checkerboard under translucent fills; opaque colors paint solid.
    Rectangle {
        x: 3px;
        y: 3px;
        width: parent.width - 28px;
        height: parent.height - 6px;
        border-radius: AppStore.theme.metrics.radius.sm;
        clip: true;
        border-width: 1px;
        border-color: #ffffff1f;

        if root.enable-alpha: ColorCheckerboard {
            width: 100%;
            height: 100%;
            cell: 4px;
        }

        Rectangle {
            width: 100%;
            height: 100%;
            background: root.live;
        }
    }

    Image {
        x: parent.width - 22px;
        width: 12px;
        height: 12px;
        y: (parent.height - self.height) / 2;
        source: @image-url("../../../../assets/icon/ui/chevron-down.svg");
        image-fit: contain;
        colorize: AppStore.theme.text.muted;
    }

    trigger := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.live = root.value;
            root.gesturing = false;
            popup.show();
        }
    }

    // Slint clamps PopupWindow into the window via place_popup — size the
    // shell for the full picker and prefer below the well.
    popup := PopupWindow {
        x: 0;
        y: root.height + 4px;
        width: 268px;
        height: shell.preferred-height;
        close-policy: PopupClosePolicy.close-on-click-outside;

        shell := Rectangle {
            width: 100%;
            height: 100%;
            background: AppStore.theme.panel.background;
            border-radius: AppStore.theme.metrics.radius.md;
            border-width: 1px;
            border-color: #ffffff1f;
            drop-shadow-blur: 12px;
            drop-shadow-color: #00000040;
            drop-shadow-offset-y: 3px;

            VerticalLayout {
                padding: AppStore.theme.metrics.spacing.md;

                CutlassColorPicker {
                    current: root.live;
                    recent-colors: root.recent-colors;
                    enable-alpha: root.enable-alpha;
                    preview(c) => {
                        root.gesturing = true;
                        root.live = c;
                        root.preview(c);
                    }
                    committed(c) => {
                        root.commit-color(c);
                    }
                    eyedropper-requested => {
                        // Clear any in-flight picker preview, then close and
                        // arm — the popup-open handler finishes the arm.
                        if (root.gesturing) {
                            root.gesturing = false;
                            root.live = root.value;
                            root.cancelled();
                        }
                        root.arming-eyedropper = true;
                        popup.close();
                    }
                }
            }
        }
    }
}
