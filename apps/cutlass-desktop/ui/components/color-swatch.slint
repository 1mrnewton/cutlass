// A color well that opens a popup palette of preset swatches. Picking a
// swatch fires `changed` with the chosen color. (Free-form hex entry would
// need a Rust-side parser since Slint can't parse hex at runtime; the curated
// palette covers the common title-color choices CapCut surfaces.)

import { AppStore } from "../store/app-store.slint";
import { AppState } from "../state.slint";
import { ColorPalette } from "color-palette.slint";

export component CutlassColorSwatch inherits Rectangle {
    in-out property <color> value: #ffffff;
    in property <bool> enabled: true;

    callback changed(value: color);

    width: 104px;
    height: 28px;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: #ffffff10;
    opacity: enabled ? 1.0 : 0.45;

    // Checkerboard would show alpha, but title colors are opaque here, so a
    // flat fill preview is enough.
    Rectangle {
        x: 3px;
        y: 3px;
        width: parent.width - 28px;
        height: parent.height - 6px;
        border-radius: AppStore.theme.metrics.radius.sm;
        background: root.value;
        border-width: 1px;
        border-color: #ffffff1f;
    }

    Image {
        x: parent.width - 22px;
        width: 12px;
        height: 12px;
        y: (parent.height - self.height) / 2;
        source: @image-url("../../../../assets/icon/ui/chevron-down.svg");
        image-fit: contain;
        colorize: AppStore.theme.text.muted;
    }

    trigger := TouchArea {
        enabled: root.enabled;
        clicked => {
            popup.show();
        }
    }

    popup := PopupWindow {
        x: 0;
        y: root.height + 4px;
        width: 244px;
        height: content.preferred-height;
        close-policy: PopupClosePolicy.close-on-click-outside;

        Rectangle {
            width: 100%;
            height: 100%;
            background: AppStore.theme.panel.background;
            border-radius: AppStore.theme.metrics.radius.md;
            border-width: 1px;
            border-color: #ffffff1f;
            drop-shadow-blur: 12px;
            drop-shadow-color: #00000040;
            drop-shadow-offset-y: 3px;

            content := VerticalLayout {
                padding: AppStore.theme.metrics.spacing.md;
                spacing: AppStore.theme.metrics.spacing.sm;

                for row in ColorPalette.swatches: HorizontalLayout {
                    spacing: AppStore.theme.metrics.spacing.sm;

                    for swatch-color in row: Rectangle {
                        width: 24px;
                        height: 24px;
                        border-radius: AppStore.theme.metrics.radius.sm;
                        background: swatch-color;
                        border-width: swatch-color == root.value ? 2px : 1px;
                        border-color: swatch-color == root.value ? AppStore.theme.accent.primary : #ffffff24;

                        TouchArea {
                            clicked => {
                                // `value` is caller-owned (bound to the model);
                                // report the pick and let the commit update it.
                                root.changed(swatch-color);
                                popup.close();
                                AppState.refocus-shortcuts();
                            }
                        }
                    }
                }
            }
        }
    }
}
