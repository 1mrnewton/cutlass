// Start screen — the full-window home shown on a cold start, before the
// editor (app.slint gates it on AppState.launch-visible and dismisses it
// from the session-epoch watcher once a real session loads).
//
// Design intent — "editorial workstation": a calm, structural project
// manager, not a consumer-app splash. Deliberately steers clear of the
// generic AI-launch look:
//   · no blue→purple gradient hero wash — the brand teal appears only on the
//     small mark + functional state, never as a full-surface gradient;
//   · structure comes from hairline borders and a compact 3-level elevation
//     (page #141414 → tile #262626 → hover #303030), not drop shadows or
//     glass/blur;
//   · the create row is asymmetric (one dominant action), not an even card
//     grid; copy is plain and task-first.
// All colour/spacing/type comes from AppStore.theme tokens.

import { CutlassText, CutlassGridView, CutlassScrollView, SubtleButton } from "components/index.slint";
import { ActionCard, CategoryChip, ProjectRow, RailNav, TemplateCard, WinButton } from "launch-components.slint";
import { AppStore, EditorStore } from "store/index.slint";
import { AppState } from "state.slint";
import { WindowBackend } from "lib/window-backend.slint";
import { TemplatesBackend, TemplateTile } from "lib/templates-backend.slint";
import { AccountBackend } from "lib/account-backend.slint";

export component LaunchScreen inherits Rectangle {
    background: AppStore.theme.surface.app-background;

    // "home" | "templates" — which screen the left rail has selected.
    property <string> active-screen: "home";

    VerticalLayout {
        spacing: AppStore.theme.metrics.spacing.none;

        // Window drag strip + caption controls (frameless window). Buttons
        // are declared after the drag TouchArea so they stack above it and
        // keep their clicks; the empty stretch has no TouchArea, so presses
        // there fall through to the drag region.
        Rectangle {
            height: AppStore.theme.metrics.layout.toolbar-height;
            background: AppStore.theme.surface.app-background;

            drag := TouchArea {
                moved => {
                    if (abs(self.mouse-x - self.pressed-x) > 2px || abs(self.mouse-y - self.pressed-y) > 2px) {
                        WindowBackend.begin-move();
                    }
                }
                double-clicked => {
                    WindowBackend.toggle-maximize();
                }
            }

            HorizontalLayout {
                Rectangle {
                    horizontal-stretch: 1;
                }

                // Custom controls only off macOS — there the native traffic
                // lights (kept on the hidden titlebar) sit over the empty left
                // of this drag strip.
                if !AppState.is-macos: WinButton {
                    icon: @image-url("../../../assets/icon/shell/minus.svg");
                    clicked => {
                        WindowBackend.minimize();
                    }
                }

                if !AppState.is-macos: WinButton {
                    icon: WindowBackend.maximized
                        ? @image-url("../../../assets/icon/shell/copy.svg")
                        : @image-url("../../../assets/icon/shell/square.svg");
                    clicked => {
                        WindowBackend.toggle-maximize();
                    }
                }

                if !AppState.is-macos: WinButton {
                    icon: @image-url("../../../assets/icon/shell/x.svg");
                    danger: true;
                    clicked => {
                        WindowBackend.close();
                    }
                }
            }
        }

        HorizontalLayout {
            vertical-stretch: 1;
            spacing: AppStore.theme.metrics.spacing.none;

            // ---- Left rail: brand · nav · footer -------------------------
            Rectangle {
                width: 252px;
                background: AppStore.theme.surface.app-background;

                // Hairline seam between rail and content.
                Rectangle {
                    x: parent.width - self.width;
                    width: AppStore.theme.metrics.stroke.hairline;
                    background: #ffffff12;
                }

                VerticalLayout {
                    padding: AppStore.theme.metrics.spacing.xl;
                    padding-top: AppStore.theme.metrics.spacing.sm;
                    spacing: AppStore.theme.metrics.spacing.lg;

                    // Brand lockup.
                    HorizontalLayout {
                        spacing: AppStore.theme.metrics.spacing.sm;

                        VerticalLayout {
                            alignment: center;

                            // Brand mark — the Cutlass wordmark logo (the
                            // sword fills the square canvas, so it sits in the
                            // mark box), replacing the earlier "C" placeholder.
                            Image {
                                width: 28px;
                                height: 28px;
                                source: @image-url("../../../assets/icon/cutlass-in-app.png");
                                image-fit: contain;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing: 0px;

                            CutlassText {
                                text: "Cutlass";
                                style: AppStore.theme.typography.heading-md;
                            }

                            CutlassText {
                                text: "Prompt-to-edit video";
                                style: AppStore.theme.typography.caption;
                                foreground: AppStore.theme.text.muted;
                            }
                        }
                    }

                    // Nav.
                    VerticalLayout {
                        spacing: 2px;

                        RailNav {
                            label: "Home";
                            active: root.active-screen == "home";
                            clicked => {
                                root.active-screen = "home";
                            }
                        }

                        RailNav {
                            label: "Templates";
                            active: root.active-screen == "templates";
                            clicked => {
                                root.active-screen = "templates";
                                if TemplatesBackend.status == "idle" {
                                    TemplatesBackend.refresh(TemplatesBackend.category);
                                }
                            }
                        }

                        RailNav {
                            label: "Learn";
                            enabled: false;
                            tag: "Soon";
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                    }

                    // Update nudge: a quiet chip at the bottom of the rail when
                    // the backend reports a newer release. Click opens the
                    // download page in the browser; never blocks anything.
                    if AccountBackend.update-available: Rectangle {
                        height: 30px;
                        border-radius: AppStore.theme.metrics.radius.sm;
                        background: update-ta.has-hover
                            ? AppStore.theme.accent.primary.with-alpha(0.22)
                            : AppStore.theme.accent.primary.with-alpha(0.14);

                        CutlassText {
                            x: AppStore.theme.metrics.spacing.md;
                            width: parent.width - 2 * AppStore.theme.metrics.spacing.md;
                            height: parent.height;
                            vertical-alignment: center;
                            text: "Update available — " + AccountBackend.update-version;
                            style: AppStore.theme.typography.caption;
                            foreground: AppStore.theme.accent.primary;
                            overflow: elide;
                        }

                        update-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                AccountBackend.open-update();
                            }
                        }
                    }
                }
            }

            // ---- Main content: greeting · create row · recents ----------
            Rectangle {
                horizontal-stretch: 1;
                background: AppStore.theme.surface.app-background;

                if root.active-screen == "home": VerticalLayout {
                    // Cap the content column so rows stay readable on a wide,
                    // maximized window; a layout child of a plain Rectangle
                    // pins to the left, so this keeps the home left-set rather
                    // than stranded mid-screen. (max-width is a static
                    // constraint — no parent.width binding loop.)
                    max-width: 1040px;
                    padding-left: AppStore.theme.metrics.spacing.xxl;
                    padding-right: AppStore.theme.metrics.spacing.xxl;
                    padding-top: AppStore.theme.metrics.spacing.lg;
                    padding-bottom: AppStore.theme.metrics.spacing.xl;
                    spacing: AppStore.theme.metrics.spacing.xl;

                    // Greeting.
                    VerticalLayout {
                        spacing: AppStore.theme.metrics.spacing.xs;

                        CutlassText {
                            text: "Start a project";
                            style: { size: 22px, weight: 600, italic: false };
                        }

                        CutlassText {
                            text: "Create a new edit, or pick up where you left off.";
                            style: AppStore.theme.typography.body;
                            foreground: AppStore.theme.text.secondary;
                        }
                    }

                    // Create row — asymmetric: one dominant action.
                    HorizontalLayout {
                        height: 156px;
                        spacing: AppStore.theme.metrics.spacing.md;

                        ActionCard {
                            // Dominant action. The explicit max-width lifts the
                            // implicit text-driven cap so the card actually
                            // stretches to fill the row (Slint sizes a
                            // text-only container to its content otherwise).
                            horizontal-stretch: 1;
                            max-width: 700px;
                            primary: true;
                            title: "New project";
                            subtitle: "Start with a blank timeline.";
                            clicked => {
                                EditorStore.on-new-requested();
                            }
                        }

                        ActionCard {
                            width: 320px;
                            title: "Open file…";
                            subtitle: "Import a .cutlass into your projects.";
                            clicked => {
                                EditorStore.on-open-requested();
                            }
                        }
                    }

                    // Project gallery.
                    VerticalLayout {
                        vertical-stretch: 1;
                        spacing: AppStore.theme.metrics.spacing.sm;

                        HorizontalLayout {
                            spacing: AppStore.theme.metrics.spacing.sm;

                            CutlassText {
                                text: "Your projects";
                                vertical-alignment: center;
                                style: AppStore.theme.typography.heading-sm;
                            }

                            if EditorStore.projects.length > 0: Rectangle {
                                width: count-text.preferred-width + 2 * AppStore.theme.metrics.spacing.sm;
                                background: #ffffff0f;
                                border-radius: AppStore.theme.metrics.radius.sm;

                                count-text := CutlassText {
                                    text: "\{EditorStore.projects.length}";
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    style: AppStore.theme.typography.caption;
                                    foreground: AppStore.theme.text.secondary;
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }
                        }

                        // Empty state — covered explicitly so a fresh install
                        // reads as intentional, not broken.
                        if EditorStore.projects.length == 0: Rectangle {
                            vertical-stretch: 1;
                            border-radius: AppStore.theme.metrics.radius.lg;
                            border-width: AppStore.theme.metrics.stroke.hairline;
                            border-color: #ffffff12;

                            VerticalLayout {
                                alignment: center;
                                spacing: AppStore.theme.metrics.spacing.xs;

                                CutlassText {
                                    text: "No projects yet";
                                    horizontal-alignment: center;
                                    style: AppStore.theme.typography.body;
                                    foreground: AppStore.theme.text.secondary;
                                }

                                CutlassText {
                                    text: "New projects you create are saved automatically and appear here.";
                                    horizontal-alignment: center;
                                    style: AppStore.theme.typography.caption;
                                    foreground: AppStore.theme.text.muted;
                                }
                            }
                        }

                        if EditorStore.projects.length > 0: project-scroll := CutlassScrollView {
                            vertical-stretch: 1;
                            viewport-width: self.width;
                            viewport-height: project-list.preferred-height;
                            show-horizontal-scrollbar: false;
                            enable-key-scroll: true;

                            project-list := VerticalLayout {
                                width: project-scroll.width;
                                spacing: 2px;
                                alignment: start;

                                for entry in EditorStore.projects: ProjectRow {
                                    name: entry.name;
                                    modified: entry.modified;
                                    open => {
                                        EditorStore.on-open-project-requested(entry.path);
                                    }
                                    remove => {
                                        EditorStore.on-delete-project-requested(entry.path);
                                    }
                                }
                            }
                        }
                    }
                }

                // ---- Templates gallery ----------------------------------
                if root.active-screen == "templates": VerticalLayout {
                    max-width: 1040px;
                    padding-left: AppStore.theme.metrics.spacing.xxl;
                    padding-right: AppStore.theme.metrics.spacing.xxl;
                    padding-top: AppStore.theme.metrics.spacing.lg;
                    padding-bottom: AppStore.theme.metrics.spacing.none;
                    spacing: AppStore.theme.metrics.spacing.lg;

                    VerticalLayout {
                        spacing: AppStore.theme.metrics.spacing.xs;

                        CutlassText {
                            text: "Templates";
                            style: { size: 22px, weight: 600, italic: false };
                        }

                        CutlassText {
                            text: "Pick a template, swap in your clips, and start from a finished edit.";
                            style: AppStore.theme.typography.body;
                            foreground: AppStore.theme.text.secondary;
                        }
                    }

                    // Category filter chips (mirror TemplateCategory).
                    HorizontalLayout {
                        spacing: AppStore.theme.metrics.spacing.sm;

                        CategoryChip {
                            value: "all";
                            label: "All";
                        }

                        CategoryChip {
                            value: "trending";
                            label: "Trending";
                        }

                        CategoryChip {
                            value: "travel";
                            label: "Travel";
                        }

                        CategoryChip {
                            value: "lifestyle";
                            label: "Lifestyle";
                        }

                        CategoryChip {
                            value: "birthday";
                            label: "Birthday";
                        }

                        CategoryChip {
                            value: "wedding";
                            label: "Wedding";
                        }

                        CategoryChip {
                            value: "slideshow";
                            label: "Slideshow";
                        }

                        CategoryChip {
                            value: "vlog";
                            label: "Vlog";
                        }

                        CategoryChip {
                            value: "gaming";
                            label: "Gaming";
                        }

                        CategoryChip {
                            value: "business";
                            label: "Business";
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }
                    }

                    if TemplatesBackend.status == "loading": VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;

                        CutlassText {
                            text: "Loading templates…";
                            horizontal-alignment: center;
                            style: AppStore.theme.typography.caption;
                            foreground: AppStore.theme.text.secondary;
                        }
                    }

                    if TemplatesBackend.status == "empty": VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        spacing: AppStore.theme.metrics.spacing.xs;

                        CutlassText {
                            text: "No templates here yet";
                            horizontal-alignment: center;
                            style: AppStore.theme.typography.body;
                            foreground: AppStore.theme.text.secondary;
                        }

                        CutlassText {
                            text: "New templates land in the catalog regularly — check back soon.";
                            horizontal-alignment: center;
                            style: AppStore.theme.typography.caption;
                            foreground: AppStore.theme.text.muted;
                        }
                    }

                    if TemplatesBackend.status == "error": VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        spacing: AppStore.theme.metrics.spacing.sm;

                        CutlassText {
                            text: "Couldn't load templates";
                            horizontal-alignment: center;
                            style: AppStore.theme.typography.heading-sm;
                        }

                        CutlassText {
                            text: TemplatesBackend.error;
                            horizontal-alignment: center;
                            style: AppStore.theme.typography.caption;
                            foreground: AppStore.theme.text.secondary;
                            wrap: word-wrap;
                        }

                        HorizontalLayout {
                            alignment: center;

                            SubtleButton {
                                label: "Retry";
                                clicked => {
                                    TemplatesBackend.refresh(TemplatesBackend.category);
                                }
                            }
                        }
                    }

                    if TemplatesBackend.status == "results": template-grid := CutlassGridView {
                        vertical-stretch: 1;
                        horizontal-stretch: 1;

                        auto-columns: true;
                        cell-width: 232px;
                        cell-height: 186px;
                        spacing: AppStore.theme.metrics.spacing.md;
                        inset: AppStore.theme.metrics.spacing.none;
                        item-count: TemplatesBackend.items.length;

                        for tile[i] in TemplatesBackend.items: TemplateCard {
                            x: template-grid.cell-x(i);
                            y: template-grid.cell-y(i);
                            width: template-grid.cell-width;
                            height: template-grid.cell-height;
                            tile: tile;
                            index: i;
                        }
                    }
                }
            }
        }
    }
}
