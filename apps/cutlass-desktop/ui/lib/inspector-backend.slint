import { CatalogEntry, Clip, ClipAdjust, Sequence, TrackKind, TextClipStyle } from "../models/index.slint";

export struct SelectedClipInfo {
    found: bool,
    track-kind: TrackKind,
    clip: Clip,
}

// Keyframe state of one animatable property at the playhead, for the
// inspector's diamond cluster (keyframes roadmap Phase 1).
export struct ParamRowState {
    // The property has at least one keyframe.
    animated: bool,
    // The playhead sits exactly on a keyframe (diamond renders filled;
    // clicking it removes instead of adds).
    on-keyframe: bool,
    // Absolute tick of the nearest keyframe strictly before / after the
    // playhead; -1 when there is none (disables the ◀ / ▶ arrow).
    prev-tick: int,
    next-tick: int,
    // Easing of the keyframe under the playhead (0 linear … 3 ease-in-out,
    // 4 bezier); only meaningful when `on-keyframe`.
    easing: int,
}

export struct ScalarParamSample {
    value: float,
    row: ParamRowState,
}

export struct TransformSample {
    position-x: float,
    position-y: float,
    anchor-x: float,
    anchor-y: float,
    scale: float,
    scale-y: float,
    scale-linked: bool,
    rotation: float,
    opacity: float,
    position-row: ParamRowState,
    anchor-row: ParamRowState,
    scale-row: ParamRowState,
    rotation-row: ParamRowState,
    opacity-row: ParamRowState,
}

// Position that keeps the rendered frame fixed while `anchor-*` moves.
export struct CompensatedPosition {
    position-x: float,
    position-y: float,
}

// The clip's audio gain + pan sampled at the playhead, plus each envelope's
// keyframe row state — the audio analogue of `TransformSample`, feeding the
// inspector's volume/pan diamonds.
export struct AudioSample {
    volume: float,
    volume-row: ParamRowState,
    pan: float,
    pan-row: ParamRowState,
}

// Selection lookup and clip-property writes for the inspector panel.
// Implemented in Rust (`src/inspector.rs`) so nested model traversal
// stays out of Slint.
export global InspectorBackend {
    // Clip blend-mode catalog (CapCut "Blend"), populated once at startup
    // from `BlendMode::ALL`.
    in-out property <[CatalogEntry]> blend-catalog: [];
    // Mask shape catalog (CapCut mask panel), populated once at startup
    // from `mask_catalog()`.
    in-out property <[CatalogEntry]> mask-catalog: [];
    // Clip-level filter preset catalog, populated once at startup.
    in-out property <[CatalogEntry]> filter-catalog: [];
    // Cloud LUT catalog (downloaded `.cube` starter pack). Populated by the
    // LUT worker after `refresh-luts`; ids map to local files Rust-side.
    in-out property <[CatalogEntry]> lut-catalog: [];
    // "idle" | "loading" | "results" | "empty" | "error"
    in-out property <string> lut-status: "idle";
    in-out property <string> lut-error: "";
    // Look animation preset catalogs, populated once at startup.
    in-out property <[CatalogEntry]> animation-in-catalog: [];
    in-out property <[CatalogEntry]> animation-out-catalog: [];
    in-out property <[CatalogEntry]> animation-combo-catalog: [];
    // Text panel: includes per-character presets (text_only) in every slot.
    in-out property <[CatalogEntry]> animation-text-in-catalog: [];
    in-out property <[CatalogEntry]> animation-text-out-catalog: [];
    in-out property <[CatalogEntry]> animation-text-combo-catalog: [];

    pure callback resolve-selection(
        sequence: Sequence,
        track-id: string,
        clip-id: string,
    ) -> SelectedClipInfo;

    // Sample the clip's animated transform at the playhead and report each
    // property's keyframe row state. Implemented in Rust over the projected
    // `kf-*` curves with the engine's own `Param` sampling math, so the
    // numbers always match the composited frame.
    pure callback sample-transform(clip: Clip, playhead-tick: int) -> TransformSample;

    // Recompute canvas position so a new in-content anchor leaves pixels
    // unchanged — the same compensation the preview anchor handle uses.
    pure callback compensate-anchor-position(
        clip: Clip,
        sequence: Sequence,
        playhead-tick: int,
        anchor-x: float,
        anchor-y: float,
        scale-x: float,
        scale-y: float,
        rotation: float,
    ) -> CompensatedPosition;

    // Sample the clip's volume + pan envelopes at the playhead and report
    // their keyframe row state, mirroring `sample-transform` for the audio
    // sheet. Implemented in Rust over the projected `kf-volume` / `kf-pan`
    // curves with the engine's `Param` math, so the readout always matches
    // the mixed gain and balance.
    pure callback sample-audio(clip: Clip, playhead-tick: int) -> AudioSample;

    // Sample a scalar text-style or look parameter by its inspector command
    // id. This is the same projected curve used for the row's keyframe state.
    pure callback sample-scalar-param(
        clip: Clip,
        param: string,
        playhead-tick: int,
    ) -> ScalarParamSample;

    // Insert or replace a keyframe on `param` ("position" | "anchor" | "scale" |
    // "rotation" | "opacity" | "volume" | "pan") at the absolute sequence tick.
    // Scalars ride `value-x`; position uses both axes. `easing`: 0 linear,
    // 1 ease-in, 2 ease-out, 3 ease-in-out. One undoable engine edit.
    callback set-param-keyframe(
        clip-id: string,
        param: string,
        tick: int,
        value-x: float,
        value-y: float,
        easing: int,
    );

    // Remove the keyframe sitting exactly at `tick` on `param`. Removing
    // the last keyframe collapses the property to a constant (engine
    // semantics). One undoable engine edit.
    callback remove-param-keyframe(clip-id: string, param: string, tick: int);

    // Replace one animatable property with a constant, dropping its
    // keyframes. Scalars ride `value-x`; vec2 params use both axes; color
    // params pack RG into `value-x` and BA into `value-y` (u16 lanes).
    // One undoable engine edit.
    callback set-param-constant(
        clip-id: string,
        param: string,
        value-x: float,
        value-y: float,
    );

    // Retime a media clip (CapCut speed, M1): positive rational `num/den`
    // playback rate (2/1 = double speed) plus the reverse flag. The engine
    // keeps the clip's timeline start and source window and re-derives the
    // timeline duration; with linkage on the clip's link partners retime
    // too. One undoable edit (the whole link group is one history entry).
    callback set-clip-speed(
        clip-id: string,
        speed-num: int,
        speed-den: int,
        reversed: bool,
    );

    // Toggle pitch preservation on a retimed media clip (CapCut "pitch"
    // switch, M8 Phase 3): true keeps the original pitch (time-stretch),
    // false lets pitch follow the speed ("chipmunk"). With linkage on the
    // clip's audio-lane link partners follow. One undoable edit.
    callback set-clip-pitch(clip-id: string, preserve: bool);

    // Toggle noise reduction on a media clip (CapCut "Reduce noise", M8
    // Phase 5): true runs the clip's audio through RNNoise in both mixers. A
    // video clip carries its own sound, so the edit lands on it directly —
    // unless its audio was detached to a linked audio lane. One undoable edit.
    callback set-denoise(clip-id: string, denoise: bool);

    // Apply a named speed-ramp preset to a media clip (CapCut speed curves,
    // M2): "ramp_up" | "ramp_down" | "montage" | "hero" | "bullet", or ""
    // (also "none"/"normal") to clear it back to a constant speed. The engine
    // re-derives the clip's timeline duration from the ramp's average; with
    // linkage on, link partners ramp too. One undoable edit.
    callback set-speed-curve(clip-id: string, preset: string);

    // Adjust one existing ramp point's speed multiplier (velocity-graph
    // drag). The worker reads the clip's current curve, replaces point
    // `index`'s value, and re-commits. One undoable edit.
    callback set-speed-curve-point(clip-id: string, index: int, value: float);

    // Set a clip's audio mix (CapCut volume + fades, M1): gain multiplier
    // (0 mutes, 1 unchanged) plus fade in/out durations in seconds. A video
    // clip carries its own sound, so the edit lands on it directly — unless its
    // audio was detached to a linked audio lane. One undoable edit.
    callback set-clip-audio(
        clip-id: string,
        volume: float,
        fade-in-s: float,
        fade-out-s: float,
    );

    // Set only a clip's fades, leaving the gain untouched — a flat level or a
    // keyframed M8 envelope, which set-clip-audio would flatten. Same linkage
    // routing as set-clip-audio. One undoable edit.
    callback set-clip-fades(
        clip-id: string,
        fade-in-s: float,
        fade-out-s: float,
    );

    // Whether a "duck under voice" gesture is possible for a clip on
    // `track-id`: true when some *other* audio lane is tagged as a voice
    // source (the track header "V" toggle, M8 Phase 4). Gates the inspector
    // button; the worker re-resolves the exact overlapping voice clips.
    pure callback can-duck-under-voice(sequence: Sequence, track-id: string) -> bool;

    // Duck the given music clip under the voice lanes (M8 Phase 4): the worker
    // gathers every clip on a voice-tagged audio lane that overlaps this clip
    // and writes the ducking dip as ordinary volume keyframes — one undoable
    // edit, editable afterwards through the volume envelope.
    callback duck-under-voice(clip-id: string);

    // Detect beat markers on a media clip (CapCut "Beat", M8 Phase 6): the
    // worker decodes the clip's audio, runs onset/tempo analysis, and stores
    // the beat grid so the timeline magnet snaps clip edges to the music. One
    // undoable edit; re-running re-detects, and clear-beats removes them.
    callback detect-beats(clip-id: string);

    // Clear a clip's detected beat markers (M8 Phase 6). One undoable edit.
    callback clear-beats(clip-id: string);

    // Set a visual clip's crop window + mirroring (CapCut crop, M1):
    // normalized inset fractions measured in from each content edge
    // (0,0,0,0 ⇔ uncropped) plus flip flags. main.rs converts insets to the
    // model's kept-region rect; the engine validates (visual lanes only,
    // non-degenerate window). `playhead-tick` is the absolute sequence tick
    // used to keyframe an already-animated crop (M2 compose). One undoable
    // edit. Also clears any live `ClipParam::Crop` override for the clip.
    callback set-clip-crop(
        clip-id: string,
        left: float,
        top: float,
        right: float,
        bottom: float,
        flip-h: bool,
        flip-v: bool,
        playhead-tick: int,
    );

    // Live crop-window preview during an inset slider drag. Same inset shape
    // as `set-clip-crop` (no flip — flips commit immediately). Session-only
    // `ClipParam::Crop` override; release commits via `set-clip-crop` or
    // clears with `clear-param-override` when nothing changed.
    callback preview-clip-crop(
        clip-id: string,
        left: float,
        top: float,
        right: float,
        bottom: float,
        tick: int,
    );

    // Drop every live param-override for `clip-id` and repaint `tick` from
    // committed state (release with no net change). Matching commits also
    // clear the param they write.
    callback clear-param-override(clip-id: string, tick: int);

    // Set a visual clip's blend mode (CapCut "Blend"). `mode` is a catalog
    // id from `blend-catalog` (e.g. "multiply"); `"normal"` is the default.
    // One undoable edit.
    callback set-clip-blend-mode(clip-id: string, mode: string);

    // Set per-clip transform motion blur. `shutter` is degrees (0..=720);
    // `samples` is quality (2..=16 in the UI). One undoable edit.
    callback set-clip-motion-blur(clip-id: string, enabled: bool, shutter: float, samples: int);

    // Set (or clear with an empty id) a visual clip's mask kind. Switching
    // kind preserves feather / invert / geometry; enabling from none uses
    // `Mask::new`. One undoable edit.
    callback set-clip-mask-kind(clip-id: string, kind: string);

    // Toggle mask invert on a clip that already has a mask. One undoable edit.
    callback set-clip-mask-invert(clip-id: string, invert: bool);

    // Enable or clear chroma keying. Enabling installs green `[0,255,0]` with
    // strength `0.5` / shadow `0`. One undoable edit.
    callback toggle-clip-chroma(clip-id: string, enabled: bool);

    // Set the chroma key color (RGB 0..=255) on a keyed clip. One undoable edit.
    callback set-clip-chroma-color(clip-id: string, r: int, g: int, b: int);

    // Enable or clear one layer-style block on a visual clip. `block` is
    // "shadow" | "glow" | "outline" | "background". Enabling installs the
    // model default for that block; disabling clears it. One undoable edit.
    callback toggle-clip-style(clip-id: string, block: string, enabled: bool);

    // Set a layer-style color param (`style_shadow_color`, …) as a constant
    // via the generic param path. Channels are 0..=255. One undoable edit.
    callback set-clip-style-color(
        clip-id: string,
        key: string,
        r: int,
        g: int,
        b: int,
        a: int,
    );

    // Live preview of one layer-style scalar (or shadow offset axis) during
    // a slider drag. `key` is a style_* param id; for offset use
    // `style_shadow_offset_x` / `_y`. Session-only — release commits via
    // set-param-constant / set-param-keyframe.
    callback preview-clip-style(clip-id: string, key: string, value: float, tick: int);

    // Live preview of one layer-style color during a swatch edit. Channels
    // are 0..=255. Session-only; the matching set-clip-style-color commits.
    callback preview-clip-style-color(
        clip-id: string,
        key: string,
        r: int,
        g: int,
        b: int,
        a: int,
        tick: int,
    );

    // Drop a lingering styles preview override and repaint `tick` from
    // committed state (release with no net change). Style slider commits
    // also clear via set-param-constant / set-layer-styles.
    callback clear-clip-styles(tick: int);

    // Set (or clear with an empty id) a visual clip's filter preset. Intensity
    // is normalized 0..=1; the inspector displays it as 0..=100%.
    callback set-clip-filter(clip-id: string, filter-id: string, intensity: float);

    // Fetch the LUT catalog and download its `.cube` files (idempotent; the
    // look inspector fires it on first open).
    callback refresh-luts();

    // Set (or clear with an empty id) a visual clip's `.cube` LUT. `lut-id`
    // is a `lut-catalog` entry id, or an absolute `.cube` path (intensity
    // re-apply / user-picked file). Catalog ids resolve to the downloaded
    // file; absolute paths pass through. Intensity is normalized 0..=1.
    // One undoable edit.
    callback set-clip-lut(clip-id: string, lut-id: string, intensity: float);

    // Open a native `.cube` file picker and apply the chosen LUT to the clip
    // at default intensity (0.8). Cancel leaves the clip unchanged.
    callback pick-clip-lut(clip-id: string);

    // Set (or clear with an empty id) one look-animation slot: "in", "out",
    // or "combo". Knobs are speed / intensity / stagger (defaults 1.0).
    // One undoable edit; combo exclusivity is enforced by the model.
    callback set-clip-animation(
        clip-id: string,
        slot: string,
        animation-id: string,
        speed: float,
        intensity: float,
        stagger: float,
    );

    // Set all manual color adjustment sliders in one undoable edit.
    // Signed values are normalized -1..=1; sharpness/vignette are 0..=1.
    callback set-clip-adjust(clip-id: string, adjust: ClipAdjust);

    // Atomic live preview of the whole look: filter plus all adjustments.
    // The worker coalesces bursts and clears this session-only override on
    // the matching commit.
    callback preview-clip-look(
        clip-id: string,
        filter-id: string,
        intensity: float,
        adjust: ClipAdjust,
        tick: int,
    );

    // Fit/fill clip helper (M1 canvas settings): re-place the clip centered
    // at aspect-fit scale (fill: false) or at the cover scale that fills the
    // canvas (fill: true). The worker computes the scale from engine state
    // (media dims × crop vs canvas) and commits one undoable
    // SetClipTransform that keyframes at `tick` on animated clips.
    callback fit-clip(clip-id: string, fill: bool, tick: int);

    // Replace a text clip's content and/or styling in one undoable edit. The
    // inspector always sends the full current style with the single changed
    // field, so the engine writes one coherent `Generator::Text`.
    callback set-text-generator(
        track-id: string,
        clip-id: string,
        content: string,
        style: TextClipStyle,
    );

    // Live preview of an uncommitted text edit (e.g. dragging the font-size
    // slider): render `tick` with the clip's generator replaced, no history
    // entry. The matching `commit`/`clear` arrives on release.
    callback preview-text-generator(
        clip-id: string,
        content: string,
        style: TextClipStyle,
        tick: int,
    );

    // Drop the live preview override and repaint `tick` from committed state
    // (control released with no net change).
    callback clear-text-generator(tick: int);

    // Replace a shape clip's reference-pixel size in one undoable edit. The
    // inspector sends the full current width/height each time.
    callback set-shape-generator(clip-id: string, width: float, height: float);

    // Live preview of an uncommitted shape resize (slider drag): render `tick`
    // with the clip's generator replaced, no history entry.
    callback preview-shape-generator(clip-id: string, width: float, height: float, tick: int);

    // Drop a lingering shape preview override.
    callback clear-shape-generator(tick: int);

    // Installed font family names for the Font picker, populated once at
    // startup (system font enumeration is slow, so it runs off the UI thread).
    in-out property <[string]> font-families: [];

    // Case-insensitive substring filter over `items`, used by the font
    // dropdown's search box. Implemented in Rust because Slint's string type
    // has no `contains`. `items` is passed in (rather than read globally) so
    // the binding re-runs when the font list finishes loading.
    pure callback filter-fonts(query: string, items: [string]) -> [string];
}
