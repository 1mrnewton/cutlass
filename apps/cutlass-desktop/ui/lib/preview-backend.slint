import { Sequence } from "../models/index.slint";

// Bridge between preview-viewport gestures and the Rust geometry helpers
// (src/preview_select.rs). The preview shows the composited canvas
// aspect-fitted (ImageFit.contain) inside a zoomable/pannable viewport; these
// callbacks own the viewport mapping and the per-clip placement math — the
// exact same `layer_placement` the compositor renders with — so picking can
// never disagree with pixels.

// Result of a preview click: the topmost visible, unlocked clip under the
// point at the current playhead tick. Empty `clip-id` ⇔ miss (letterbox
// bar, empty canvas, or only locked/hidden layers there).
export struct PreviewHit {
    track-id: string,
    clip-id: string,
}

// Selection outline geometry in viewport-element coordinates (logical px
// as floats; multiply by 1px). The quad is delivered as four corners —
// clockwise from the content's top-left, rotation already applied — because
// Slint can't rotate a Rectangle; the panel strokes them with a Path. The
// corners double as the scale handles; (hx, hy) anchors the rotate
// affordance, a constant distance below the content's bottom edge (rides
// the rotation). `visible` is false when nothing is selected, the selected
// clip isn't under the playhead, or its lane is hidden.
export struct PreviewSelectionBox {
    visible: bool,
    x0: float, y0: float,
    x1: float, y1: float,
    x2: float, y2: float,
    x3: float, y3: float,
    hx: float, hy: float,
    // Anchor pivot in viewport coordinates (CapCut crosshair handle).
    ax: float, ay: float,
}

// Resolution of a move gesture (resolve-drag) or an arrow-key nudge. One
// result drives both the live preview (worker transform override) and the
// release commit, so they can never disagree.
//
// `valid` ⇔ the clip is draggable (visual, enabled lane, not locked).
// `moved` ⇔ the resolved position differs from the committed one — a click
// without displacement (or a drag the magnet returned home) commits nothing.
// position is the new normalized `ClipTransform` position; scale/rotation/
// opacity pass the clip's committed values through for the commit message.
// snap-h / snap-v light the horizontal / vertical canvas-center guides,
// drawn at guide-y / guide-x (viewport-element logical px).
export struct PreviewDragResolution {
    valid: bool,
    moved: bool,
    position-x: float,
    position-y: float,
    anchor-x: float,
    anchor-y: float,
    scale: float,
    scale-y: float,
    rotation: float,
    opacity: float,
    snap-h: bool,
    snap-v: bool,
    guide-x: float,
    guide-y: float,
}

// A docked-preview inspect viewport state (zoom + pan). This is UI-only — it
// changes how the composited frame is viewed, never the project. `zoom` is a
// multiple of the aspect-fit scale (1 = ImageFit.contain, <1 shrinks, >1
// magnifies); `pan-x`/`pan-y` are the content center's offset from the
// viewport center in logical px (0 = centered). Always returned pre-clamped
// to a renderable state (src/preview_view.rs).
export struct PreviewView {
    zoom: float,
    pan-x: float,
    pan-y: float,
}

// On-canvas sprite image placement during a zero-drift transform gesture.
// The sprite raster is the full fitted canvas with the clip at identity
// transform; these properties map it to the live gesture transform in
// viewport-element coordinates (logical px).
export struct PreviewSpritePlacement {
    visible: bool,
    x: float,
    y: float,
    width: float,
    height: float,
    origin-x: float,
    origin-y: float,
    rotation-degrees: float,
    scale: float,
    opacity: float,
}

// One keyframe diamond on the motion-path overlay (viewport-element px).
// When `selected`, `has-handles` lights the out/in tangent tips at
// (out-x, out-y) / (in-x, in-y) — also viewport px.
export struct MotionPathKeyframe {
    x: float,
    y: float,
    tick: int,
    selected: bool,
    has-handles: bool,
    out-x: float,
    out-y: float,
    in-x: float,
    in-y: float,
}

// Motion-path overlay for a selected clip whose position is keyframed.
// `path-commands` is SVG path data ("M x y L x y …") in viewport px —
// one string, cheap to diff. Empty / invisible when position isn't animated.
export struct MotionPath {
    visible: bool,
    path-commands: string,
    keyframes: [MotionPathKeyframe],
}

// Resolved motion-path drag: canvas-fraction position (mode 1) or tangent
// offset (modes 2/3). `valid` is false when the keyframe/clip is unknown.
// Anchor/scale/rotation/opacity pass the playhead sample through for the
// live transform override during a keyframe drag.
export struct MotionPathDragResolution {
    valid: bool,
    x: float,
    y: float,
    anchor-x: float,
    anchor-y: float,
    scale: float,
    scale-y: float,
    rotation: float,
    opacity: float,
}

// Eyedropper sample at a viewport point: `hit` is false over letterbox
// bars or when no frame is available. `loupe` is an 11×11 nearest-neighbor
// neighborhood (display with `image-rendering: pixelated`).
export struct EyedropperSample {
    hit: bool,
    color: color,
    loupe: image,
    label: string,
}

// On-canvas mask gizmo (viewport-element logical px). Geometry from
// `src/preview_mask_gizmo.rs`. Handle hit ids: 0=none, 1=center, 2=body,
// 3=size-x, 4=size-y, 5=rotation, 6=feather, 7=roundness. `outline2` is the
// second Mirror band edge (empty for other kinds). Param fields are the
// sampled/live model values used to build the overlay (layer fractions /
// degrees) so drag commits don't re-sample a stale projection.
export struct MaskGizmo {
    visible: bool,
    kind: string,
    outline-commands: string,
    outline2-commands: string,
    center-x: float,
    center-y: float,
    has-size-x: bool,
    size-x-x: float,
    size-x-y: float,
    has-size-y: bool,
    size-y-x: float,
    size-y-y: float,
    rotation-x: float,
    rotation-y: float,
    feather-x: float,
    feather-y: float,
    has-roundness: bool,
    roundness-x: float,
    roundness-y: float,
    center-fx: float,
    center-fy: float,
    size-w: float,
    size-h: float,
    rotation-deg: float,
    feather: float,
    roundness: float,
}

export global PreviewBackend {
    // Sample the composited preview frame under the cursor (widget px →
    // frame pixel via viewport_mapping). Letterbox → hit=false.
    pure callback sample-preview(image  /* frame */, float  /* x */, float  /* y */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, float  /* canvas-w */, float  /* canvas-h */, bool   /* enable-alpha */, ) -> EyedropperSample;

    // Zero-size placeholder used to drop the eyedropper's frozen source
    // frame on disarm (releases the SharedPixelBuffer retain).
    pure callback empty-frame() -> image;

    // Topmost hit at (x, y) in viewport-element coordinates, given the
    // viewport's current size and zoom/pan. Locked lanes don't hit-test
    // (same rule as the timeline); hidden lanes aren't composited so they
    // can't be hit.
    pure callback hit-test(Sequence /* sequence */, int    /* playhead-tick */, float  /* x */, float  /* y */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, ) -> PreviewHit;

    // Whether (x, y) lands on the selected clip's box, *ignoring* the letterbox
    // guard the normal hit-test uses. Lets a press on a selected clip whose
    // content overflows the frame (e.g. a long title) out in the letterbox grab
    // it to drag, instead of deselecting. (src/preview_select.rs)
    pure callback selected-contains(Sequence /* sequence */, string /* clip-id */, int    /* playhead-tick */, float  /* x */, float  /* y */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, ) -> bool;

    // Outline of `clip-id` (the primary selection) at the playhead tick,
    // mapped into viewport-element coordinates. While a gesture is live the
    // projection still holds the press-time transform, so the panel passes
    // the gesture's resolution (`gesture-active` + `gesture`) to keep the
    // box glued to the moving/scaling/rotating content.
    pure callback selection-box(Sequence /* sequence */, string /* clip-id */, int    /* playhead-tick */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, bool   /* gesture-active */, PreviewDragResolution /* gesture */, ) -> PreviewSelectionBox;

    // Sprite image placement for a zero-drift transform gesture: maps the
    // identity-transform raster to the live gesture transform using the same
    // placement math as the selection box.
    pure callback sprite-placement(Sequence /* sequence */, string /* clip-id */, int    /* playhead-tick */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, bool   /* gesture-active */, PreviewDragResolution /* gesture */, ) -> PreviewSpritePlacement;

    // Motion-path overlay for a selected clip with keyframed position:
    // sampled polyline (SVG commands) + keyframe diamonds in viewport px.
    // `selected-tick` marks one diamond (-1 ⇔ none). `edit-mode` 0=none,
    // 1=move keyframe, 2=out tangent, 3=in tangent — live path preview
    // while dragging (`edit-x`/`edit-y` are canvas fractions / offsets).
    pure callback motion-path(Sequence /* sequence */, string /* clip-id */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, int    /* selected-tick */, int    /* edit-mode */, int    /* edit-tick */, float  /* edit-x */, float  /* edit-y */, bool   /* mirror */, ) -> MotionPath;

    // Cursor (viewport px) → canvas-fraction edit values for the active
    // motion-path drag mode (see motion-path).
    pure callback resolve-motion-path-drag(Sequence /* sequence */, string /* clip-id */, int    /* playhead-tick */, float  /* cursor-x */, float  /* cursor-y */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, int    /* edit-mode */, int    /* edit-tick */, ) -> MotionPathDragResolution;

    // Select a motion-path keyframe diamond (`tick` absolute, or -1 to clear).
    // Selection-only — does not mutate the project.
    callback motion-path-select-keyframe(tick: int);

    // Commit a dragged keyframe's new canvas-fraction position at `tick`,
    // preserving that keyframe's easing and spatial tangents.
    callback motion-path-commit-keyframe(clip-id: string, tick: int, x: float, y: float);

    // Commit spatial tangents on the position keyframe at `tick`.
    callback motion-path-commit-tangents(clip-id: string, tick: int, out-x: float, out-y: float, in-x: float, in-y: float);

    // Mask gizmo overlay for a selected clip that has a mask. When
    // `live-active` is true the live-* fields replace playhead samples so
    // the handles track ParamOverride / on-canvas drags.
    pure callback mask-gizmo(Sequence /* sequence */, string /* clip-id */, int    /* playhead-tick */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, bool   /* live-active */, float  /* live-center-x */, float  /* live-center-y */, float  /* live-size-w */, float  /* live-size-h */, float  /* live-rotation */, float  /* live-feather */, float  /* live-roundness */, ) -> MaskGizmo;

    // Handle under (x, y) in viewport px (see MaskGizmo hit ids). Rebuilds
    // layout from the same inputs as mask-gizmo.
    pure callback hit-test-mask-gizmo(Sequence /* sequence */, string /* clip-id */, int    /* playhead-tick */, float  /* x */, float  /* y */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, bool   /* live-active */, float  /* live-center-x */, float  /* live-center-y */, float  /* live-size-w */, float  /* live-size-h */, float  /* live-rotation */, float  /* live-feather */, float  /* live-roundness */, float  /* tolerance */, ) -> int;

    // Move gesture (preview roadmap Phase 3): press point + current cursor
    // (viewport-element px) → new normalized position, center-guide magnet
    // applied within `snap-tolerance-px`. Called on every pointer move; the
    // result feeds the live override and the release commit. The playhead
    // tick anchors animated clips: the gesture starts from the transform the
    // frame renders (M2), not the clip-start sample.
    pure callback resolve-drag(Sequence /* sequence */, string /* clip-id */, int    /* playhead-tick */, float  /* press-x */, float  /* press-y */, float  /* cursor-x */, float  /* cursor-y */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, float  /* snap-tolerance-px */, ) -> PreviewDragResolution;

    // Arrow-key nudge: displace the clip by whole canvas pixels (from its
    // playhead-sampled position on animated clips). Invalid when the
    // selected clip isn't draggable — the caller falls through to the
    // transport frame-step binding.
    pure callback nudge(Sequence /* sequence */, string /* clip-id */, int    /* playhead-tick */, float  /* dx-canvas-px */, float  /* dy-canvas-px */, ) -> PreviewDragResolution;

    // Corner-handle scale gesture (preview roadmap Phase 4): uniform about
    // the content center, factor = cursor distance ÷ press distance from
    // the center, clamped at a minimum so the box stays grabbable.
    pure callback resolve-scale(Sequence /* sequence */, string /* clip-id */, int    /* playhead-tick */, float  /* press-x */, float  /* press-y */, float  /* cursor-x */, float  /* cursor-y */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, ) -> PreviewDragResolution;

    // Rotate-affordance gesture: cursor angle about the anchor relative to
    // the press, added to the committed rotation; magnets to the cardinal
    // angles within `snap-tolerance-deg`. The resolution's `rotation` also
    // feeds the live degree tooltip.
    pure callback resolve-rotate(Sequence /* sequence */, string /* clip-id */, int    /* playhead-tick */, float  /* press-x */, float  /* press-y */, float  /* cursor-x */, float  /* cursor-y */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, float  /* snap-tolerance-deg */, ) -> PreviewDragResolution;

    // Anchor-handle drag: move the pivot within the content while keeping
    // the rendered frame fixed — updates both anchor and position.
    pure callback resolve-anchor(Sequence /* sequence */, string /* clip-id */, int    /* playhead-tick */, float  /* press-x */, float  /* press-y */, float  /* cursor-x */, float  /* cursor-y */, float  /* view-w */, float  /* view-h */, float  /* zoom */, float  /* pan-x */, float  /* pan-y */, ) -> PreviewDragResolution;

    // --- inspect viewport zoom/pan (src/preview_view.rs) -------------------
    // Pure math over (canvas px, viewport px) → a clamped PreviewView. The
    // panel feeds back the result it gets, so the state can never drift out
    // of range (e.g. on a panel resize, or a pan past the content edge).

    // Re-normalize a viewport state: clamp zoom into range, then clamp pan to
    // what that zoom allows. Used on resize and after any external change.
    pure callback clamp-view(float /* canvas-w */, float /* canvas-h */, float /* view-w */, float /* view-h */, float /* zoom */, float /* pan-x */, float /* pan-y */, ) -> PreviewView;

    // Zoom toward `target-zoom` keeping the canvas point under the cursor
    // pinned (Ctrl/Cmd-scroll, trackpad pinch). Cursor is viewport px.
    pure callback zoom-to(float /* canvas-w */, float /* canvas-h */, float /* view-w */, float /* view-h */, float /* zoom */, float /* pan-x */, float /* pan-y */, float /* cursor-x */, float /* cursor-y */, float /* target-zoom */, ) -> PreviewView;

    // Pan by a viewport-px delta (two-finger scroll / drag), clamped to range.
    pure callback pan-view(float /* canvas-w */, float /* canvas-h */, float /* view-w */, float /* view-h */, float /* zoom */, float /* pan-x */, float /* pan-y */, float /* dx */, float /* dy */, ) -> PreviewView;
}
