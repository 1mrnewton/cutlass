// Clip-level look animations (CapCut In / Out / Combo tabs). Values are
// projected from the engine; picks route to undoable SetClipAnimation edits.

import { CutlassScrollView, CutlassText, CutlassSlider } from "../../components/index.slint";
import { AppState } from "../../state.slint";
import { AppStore, TimelineStore } from "../../store/index.slint";
import { InspectorBackend } from "../../lib/inspector-backend.slint";
import { Clip, CatalogEntry } from "../../models/index.slint";
import { LabelCell, SectionHeader, SliderRow } from "inspector-widgets.slint";

component AnimationPresetRow inherits Rectangle {
    in property <string> label;
    in property <string> id;
    in property <bool> selected;
    callback picked(id: string);

    height: 26px;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: root.selected
        ? AppStore.theme.accent.primary.with-alpha(0.12)
        : (ta.has-hover ? #ffffff10 : transparent);

    CutlassText {
        x: AppStore.theme.metrics.spacing.sm;
        width: parent.width - 2 * AppStore.theme.metrics.spacing.sm;
        height: parent.height;
        vertical-alignment: center;
        text: root.label;
        style: AppStore.theme.typography.body;
        foreground: root.selected ? AppStore.theme.accent.primary : AppStore.theme.text.primary;
        overflow: TextOverflow.elide;
    }

    ta := TouchArea {
        clicked => {
            root.picked(root.id);
            AppState.refocus-shortcuts();
        }
    }
}

component AnimationDropdown inherits Rectangle {
    in property <string> current-id;
    in property <string> current-label;
    in property <[CatalogEntry]> catalog;

    callback selected(id: string);

    height: 28px;
    horizontal-stretch: 1;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: trigger.has-hover ? #232323 : #1a1a1a;

    HorizontalLayout {
        padding-left: AppStore.theme.metrics.spacing.sm;
        padding-right: AppStore.theme.metrics.spacing.sm;
        spacing: AppStore.theme.metrics.spacing.xs;

        CutlassText {
            horizontal-stretch: 1;
            vertical-alignment: center;
            text: root.current-id == "" ? "None" : root.current-label;
            style: AppStore.theme.typography.body;
            foreground: root.current-id == "" ? AppStore.theme.text.muted : AppStore.theme.text.primary;
            overflow: TextOverflow.elide;
        }

        Rectangle {
            width: 12px;
            vertical-stretch: 1;

            Image {
                width: 12px;
                height: 12px;
                y: (parent.height - self.height) / 2;
                source: @image-url("../../../../../assets/icon/ui/chevron-down.svg");
                image-fit: contain;
                colorize: AppStore.theme.text.muted;
            }
        }
    }

    trigger := TouchArea {
        clicked => {
            popup.show();
        }
    }

    popup := PopupWindow {
        x: 0;
        y: root.height + 4px;
        width: root.width;
        height: 220px;
        close-policy: PopupClosePolicy.close-on-click-outside;

        Rectangle {
            width: 100%;
            height: 100%;
            background: AppStore.theme.panel.background;
            border-radius: AppStore.theme.metrics.radius.md;
            border-width: 1px;
            border-color: #ffffff1f;
            drop-shadow-blur: 12px;
            drop-shadow-color: #00000040;
            drop-shadow-offset-y: 3px;

            VerticalLayout {
                padding: AppStore.theme.metrics.spacing.sm;
                spacing: 0;

                CutlassScrollView {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    viewport-height: list.preferred-height;
                    show-horizontal-scrollbar: false;
                    interactive: false;

                    list := VerticalLayout {
                        spacing: 0;
                        alignment: LayoutAlignment.start;

                        AnimationPresetRow {
                            label: "None";
                            id: "";
                            selected: root.current-id == "";
                            picked(id) => {
                                root.selected(id);
                                popup.close();
                            }
                        }

                        for entry in root.catalog: AnimationPresetRow {
                            label: entry.label;
                            id: entry.id;
                            selected: entry.id == root.current-id;
                            picked(id) => {
                                root.selected(id);
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

// Speed / intensity / stagger knobs for one animation slot.
component AnimationParamSliders inherits VerticalLayout {
    in property <string> slot;
    in property <string> anim-id;
    in property <float> speed;
    in property <float> intensity;
    in property <float> stagger;
    in property <bool> has-speed;
    in property <bool> has-intensity;
    in property <bool> has-stagger;
    in property <string> clip-id;

    spacing: AppStore.theme.metrics.spacing.sm;
    alignment: LayoutAlignment.start;
    visible: root.anim-id != "";

    function commit(speed-v: float, intensity-v: float, stagger-v: float) {
        InspectorBackend.set-clip-animation(
            root.clip-id,
            root.slot,
            root.anim-id,
            speed-v,
            intensity-v,
            stagger-v,
        );
    }

    function preview(key: string, value: float) {
        InspectorBackend.preview-clip-animation(
            root.clip-id, root.slot, key, value, TimelineStore.playhead-tick);
    }

    if root.has-speed: SliderRow {
        label: "Speed";
        suffix: "×";
        value: root.speed;
        minimum: 0.25;
        maximum: 4;
        reset-value: 1;
        preview(v) => {
            root.preview("speed", clamp(v, 0.25, 4));
        }
        commit(v) => {
            root.commit(clamp(v, 0.25, 4), root.intensity, root.stagger);
        }
    }

    if root.has-intensity: SliderRow {
        label: "Intensity";
        suffix: "";
        value: root.intensity;
        minimum: 0;
        maximum: 2;
        reset-value: 1;
        preview(v) => {
            root.preview("intensity", clamp(v, 0, 2));
        }
        commit(v) => {
            root.commit(root.speed, clamp(v, 0, 2), root.stagger);
        }
    }

    if root.has-stagger: SliderRow {
        label: "Stagger";
        suffix: "";
        value: root.stagger;
        minimum: 0;
        maximum: 2;
        reset-value: 1;
        preview(v) => {
            root.preview("stagger", clamp(v, 0, 2));
        }
        commit(v) => {
            root.commit(root.speed, root.intensity, clamp(v, 0, 2));
        }
    }
}

export component AnimationInspector inherits VerticalLayout {
    in property <Clip> model;
    in property <bool> text-only-combos: false;

    spacing: AppStore.theme.metrics.spacing.lg;
    alignment: LayoutAlignment.start;

    SectionHeader {
        title: "Entrance";
    }

    HorizontalLayout {
        spacing: AppStore.theme.metrics.spacing.md;
        height: 28px;
        vertical-stretch: 0;

        LabelCell {
            label: "In";
        }

        AnimationDropdown {
            current-id: root.model.animation-in-id;
            current-label: root.model.animation-in-label;
            catalog: root.text-only-combos
                ? InspectorBackend.animation-text-in-catalog
                : InspectorBackend.animation-in-catalog;
            selected(id) => {
                InspectorBackend.set-clip-animation(root.model.id, "in", id, 1, 1, 1);
            }
        }
    }

    AnimationParamSliders {
        slot: "in";
        clip-id: root.model.id;
        anim-id: root.model.animation-in-id;
        speed: root.model.animation-in-speed;
        intensity: root.model.animation-in-intensity;
        stagger: root.model.animation-in-stagger;
        has-speed: root.model.animation-in-has-speed;
        has-intensity: root.model.animation-in-has-intensity;
        has-stagger: root.model.animation-in-has-stagger;
    }

    SectionHeader {
        title: "Exit";
    }

    HorizontalLayout {
        spacing: AppStore.theme.metrics.spacing.md;
        height: 28px;
        vertical-stretch: 0;

        LabelCell {
            label: "Out";
        }

        AnimationDropdown {
            current-id: root.model.animation-out-id;
            current-label: root.model.animation-out-label;
            catalog: root.text-only-combos
                ? InspectorBackend.animation-text-out-catalog
                : InspectorBackend.animation-out-catalog;
            selected(id) => {
                InspectorBackend.set-clip-animation(root.model.id, "out", id, 1, 1, 1);
            }
        }
    }

    AnimationParamSliders {
        slot: "out";
        clip-id: root.model.id;
        anim-id: root.model.animation-out-id;
        speed: root.model.animation-out-speed;
        intensity: root.model.animation-out-intensity;
        stagger: root.model.animation-out-stagger;
        has-speed: root.model.animation-out-has-speed;
        has-intensity: root.model.animation-out-has-intensity;
        has-stagger: root.model.animation-out-has-stagger;
    }

    SectionHeader {
        title: "Combo";
    }

    HorizontalLayout {
        spacing: AppStore.theme.metrics.spacing.md;
        height: 28px;
        vertical-stretch: 0;

        LabelCell {
            label: "Loop";
        }

        AnimationDropdown {
            current-id: root.model.animation-combo-id;
            current-label: root.model.animation-combo-label;
            catalog: root.text-only-combos
                ? InspectorBackend.animation-text-combo-catalog
                : InspectorBackend.animation-combo-catalog;
            selected(id) => {
                InspectorBackend.set-clip-animation(root.model.id, "combo", id, 1, 1, 1);
            }
        }
    }

    AnimationParamSliders {
        slot: "combo";
        clip-id: root.model.id;
        anim-id: root.model.animation-combo-id;
        speed: root.model.animation-combo-speed;
        intensity: root.model.animation-combo-intensity;
        stagger: root.model.animation-combo-stagger;
        has-speed: root.model.animation-combo-has-speed;
        has-intensity: root.model.animation-combo-has-intensity;
        has-stagger: root.model.animation-combo-has-stagger;
    }
}
