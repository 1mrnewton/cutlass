// Clip-level color grading: catalog filters plus manual adjustments. Values
// are projected from the engine; slider drags preview through the worker's
// session-only look override and release commits one undoable edit.

import { CutlassText, CutlassScrollView } from "../../components/index.slint";
import { AppState } from "../../state.slint";
import { AppStore, TimelineStore } from "../../store/index.slint";
import { InspectorBackend, ScalarParamSample } from "../../lib/inspector-backend.slint";
import { CatalogEntry, Clip } from "../../models/index.slint";
import { LabelCell, SectionHeader, SliderRow } from "inspector-widgets.slint";

component FilterRow inherits Rectangle {
    in property <string> label;
    in property <string> id;
    in property <bool> selected;
    callback picked(id: string, label: string);

    height: 26px;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: root.selected
        ? AppStore.theme.accent.primary.with-alpha(0.12)
        : (ta.has-hover ? #ffffff10 : transparent);

    CutlassText {
        x: AppStore.theme.metrics.spacing.sm;
        width: parent.width - 2 * AppStore.theme.metrics.spacing.sm;
        height: parent.height;
        vertical-alignment: center;
        text: root.label;
        style: AppStore.theme.typography.body;
        foreground: root.selected ? AppStore.theme.accent.primary : AppStore.theme.text.primary;
        overflow: TextOverflow.elide;
    }

    ta := TouchArea {
        clicked => {
            root.picked(root.id, root.label);
            AppState.refocus-shortcuts();
        }
    }
}

component FilterDropdown inherits Rectangle {
    in property <[CatalogEntry]> entries: InspectorBackend.filter-catalog;
    in property <string> current-id;
    in property <string> current-label;
    // When true, pin a Browse… row under the catalog list (LUT preset).
    in property <bool> show-browse: false;

    callback selected(id: string);
    callback browse();

    height: 28px;
    horizontal-stretch: 1;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: trigger.has-hover ? #232323 : #1a1a1a;

    HorizontalLayout {
        padding-left: AppStore.theme.metrics.spacing.sm;
        padding-right: AppStore.theme.metrics.spacing.sm;
        spacing: AppStore.theme.metrics.spacing.xs;

        CutlassText {
            horizontal-stretch: 1;
            vertical-alignment: center;
            text: root.current-id == "" ? "None" : root.current-label;
            style: AppStore.theme.typography.body;
            foreground: root.current-id == "" ? AppStore.theme.text.muted : AppStore.theme.text.primary;
            overflow: TextOverflow.elide;
        }

        Rectangle {
            width: 12px;
            vertical-stretch: 1;

            Image {
                width: 12px;
                height: 12px;
                y: (parent.height - self.height) / 2;
                source: @image-url("../../../../../assets/icon/ui/chevron-down.svg");
                image-fit: contain;
                colorize: AppStore.theme.text.muted;
            }
        }
    }

    trigger := TouchArea {
        clicked => {
            popup.show();
        }
    }

    popup := PopupWindow {
        x: 0;
        y: root.height + 4px;
        width: root.width;
        height: 260px;
        close-policy: PopupClosePolicy.close-on-click-outside;

        Rectangle {
            width: 100%;
            height: 100%;
            background: AppStore.theme.panel.background;
            border-radius: AppStore.theme.metrics.radius.md;
            border-width: 1px;
            border-color: #ffffff1f;
            drop-shadow-blur: 12px;
            drop-shadow-color: #00000040;
            drop-shadow-offset-y: 3px;

            VerticalLayout {
                padding: AppStore.theme.metrics.spacing.sm;
                spacing: 0;

                // Dedicated row (not FilterRow): avoid refocus-shortcuts, which
                // steals focus and can cancel the native file sheet. Call
                // browse before close so the callback isn't torn down with the
                // popup.
                if root.show-browse: Rectangle {
                    height: 26px;
                    border-radius: AppStore.theme.metrics.radius.sm;
                    background: browse-ta.has-hover ? #ffffff10 : transparent;

                    CutlassText {
                        x: AppStore.theme.metrics.spacing.sm;
                        width: parent.width - 2 * AppStore.theme.metrics.spacing.sm;
                        height: parent.height;
                        vertical-alignment: center;
                        text: "Browse…";
                        style: AppStore.theme.typography.body;
                        foreground: AppStore.theme.text.primary;
                    }

                    browse-ta := TouchArea {
                        clicked => {
                            root.browse();
                            popup.close();
                        }
                    }
                }

                if root.show-browse: Rectangle {
                    height: 1px;
                    background: #ffffff12;
                }

                CutlassScrollView {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    viewport-height: list.preferred-height;
                    show-horizontal-scrollbar: false;
                    interactive: false;

                    list := VerticalLayout {
                        spacing: 0;
                        alignment: LayoutAlignment.start;

                        FilterRow {
                            label: "None";
                            id: "";
                            selected: root.current-id == "";
                            picked(id, _) => {
                                root.selected(id);
                                popup.close();
                            }
                        }

                        for entry in root.entries: FilterRow {
                            label: entry.label;
                            id: entry.id;
                            selected: entry.id == root.current-id;
                            picked(id, _) => {
                                root.selected(id);
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

export component LookInspector inherits VerticalLayout {
    in property <Clip> model;

    spacing: AppStore.theme.metrics.spacing.lg;
    alignment: LayoutAlignment.start;
    private property <bool> playhead-inside: TimelineStore.playhead-tick >= model.timeline-start.value
        && TimelineStore.playhead-tick < model.timeline-start.value + model.source-range.duration.value;
    private property <ScalarParamSample> filter-sample: InspectorBackend.sample-scalar-param(model, "look_filter_intensity", TimelineStore.playhead-tick);
    private property <ScalarParamSample> lut-sample: InspectorBackend.sample-scalar-param(model, "look_lut_intensity", TimelineStore.playhead-tick);
    private property <ScalarParamSample> brightness-sample: InspectorBackend.sample-scalar-param(model, "look_adjust_brightness", TimelineStore.playhead-tick);
    private property <ScalarParamSample> contrast-sample: InspectorBackend.sample-scalar-param(model, "look_adjust_contrast", TimelineStore.playhead-tick);
    private property <ScalarParamSample> saturation-sample: InspectorBackend.sample-scalar-param(model, "look_adjust_saturation", TimelineStore.playhead-tick);
    private property <ScalarParamSample> exposure-sample: InspectorBackend.sample-scalar-param(model, "look_adjust_exposure", TimelineStore.playhead-tick);
    private property <ScalarParamSample> temperature-sample: InspectorBackend.sample-scalar-param(model, "look_adjust_temperature", TimelineStore.playhead-tick);

    function toggle-kf(param: string, on-keyframe: bool, value: float) {
        if (on-keyframe) {
            InspectorBackend.remove-param-keyframe(model.id, param, TimelineStore.playhead-tick);
        } else {
            InspectorBackend.set-param-keyframe(model.id, param, TimelineStore.playhead-tick, value, 0, 0);
        }
    }

    function ease-kf(param: string, easing: int, value: float) {
        InspectorBackend.set-param-keyframe(model.id, param, TimelineStore.playhead-tick, value, 0, easing);
    }

    init => {
        // First open fetches the LUT catalog; later opens reuse the result
        // (the worker also serves cached catalogs offline).
        if (InspectorBackend.lut-status == "idle") {
            InspectorBackend.refresh-luts();
        }
    }

    function preview-look(
        filter-id: string,
        intensity: float,
        brightness: float,
        contrast: float,
        saturation: float,
        exposure: float,
        temperature: float,
    ) {
        InspectorBackend.preview-clip-look(
            root.model.id,
            filter-id,
            intensity,
            brightness,
            contrast,
            saturation,
            exposure,
            temperature,
            TimelineStore.playhead-tick);
    }

    function commit-adjust(
        brightness: float,
        contrast: float,
        saturation: float,
        exposure: float,
        temperature: float,
    ) {
        InspectorBackend.set-clip-adjust(
            root.model.id,
            brightness,
            contrast,
            saturation,
            exposure,
            temperature);
    }

    SectionHeader {
        title: "Filter";
    }

    HorizontalLayout {
        spacing: AppStore.theme.metrics.spacing.md;
        height: 28px;
        vertical-stretch: 0;

        LabelCell {
            label: "Preset";
        }

        FilterDropdown {
            current-id: root.model.filter-id;
            current-label: root.model.filter-label;
            selected(id) => {
                InspectorBackend.set-clip-filter(root.model.id, id, id == "" ? 0 : 0.8);
            }
        }
    }

    if root.model.filter-id != "": SliderRow {
        label: "Intensity";
        suffix: "%";
        value: root.filter-sample.value * 100;
        minimum: 0;
        maximum: 100;
        step: 1;
        decimals: 0;
        reset-value: 80;
        preview(v) => {
            root.preview-look(
                root.model.filter-id,
                clamp(v, 0, 100) / 100,
                root.model.adjust-brightness,
                root.model.adjust-contrast,
                root.model.adjust-saturation,
                root.model.adjust-exposure,
                root.model.adjust-temperature);
        }
        commit(v) => {
            InspectorBackend.set-clip-filter(
                root.model.id,
                root.model.filter-id,
                clamp(v, 0, 100) / 100);
        }
        kf-visible: true;
        kf: root.filter-sample.row;
        kf-can-toggle: root.playhead-inside;
        kf-toggle => {
            root.toggle-kf("look_filter_intensity", root.filter-sample.row.on-keyframe, root.filter-sample.value);
        }
        kf-set-easing(e) => {
            root.ease-kf("look_filter_intensity", e, root.filter-sample.value);
        }
    }

    SectionHeader {
        title: "LUT";
    }

    HorizontalLayout {
        spacing: AppStore.theme.metrics.spacing.md;
        height: 28px;
        vertical-stretch: 0;

        LabelCell {
            label: "Preset";
        }

        FilterDropdown {
            entries: InspectorBackend.lut-catalog;
            current-id: root.model.lut-id;
            current-label: root.model.lut-label;
            show-browse: true;
            selected(id) => {
                InspectorBackend.set-clip-lut(root.model.id, id, id == "" ? 0 : 0.8);
            }
            browse => {
                InspectorBackend.pick-clip-lut(root.model.id);
            }
        }
    }

    if InspectorBackend.lut-status == "loading": CutlassText {
        text: "Loading LUT catalog…";
        style: AppStore.theme.typography.caption;
        foreground: AppStore.theme.text.muted;
    }

    if InspectorBackend.lut-status == "error": CutlassText {
        text: InspectorBackend.lut-error;
        style: AppStore.theme.typography.caption;
        foreground: AppStore.theme.text.muted;
        wrap: word-wrap;
    }

    if root.model.lut-path != "": SliderRow {
        label: "Intensity";
        suffix: "%";
        value: root.lut-sample.value * 100;
        minimum: 0;
        maximum: 100;
        step: 1;
        decimals: 0;
        reset-value: 80;
        // No live preview: LUT application has no session override yet,
        // so the slider commits on release only.
        preview(v) => { }
        commit(v) => {
            InspectorBackend.set-clip-lut(
                root.model.id,
                root.model.lut-path,
                clamp(v, 0, 100) / 100);
        }
        kf-visible: true;
        kf: root.lut-sample.row;
        kf-can-toggle: root.playhead-inside;
        kf-toggle => {
            root.toggle-kf("look_lut_intensity", root.lut-sample.row.on-keyframe, root.lut-sample.value);
        }
        kf-set-easing(e) => {
            root.ease-kf("look_lut_intensity", e, root.lut-sample.value);
        }
    }

    SectionHeader {
        title: "Adjust";
    }

    SliderRow {
        label: "Brightness";
        suffix: "%";
        value: root.brightness-sample.value * 100;
        minimum: -100;
        maximum: 100;
        step: 1;
        reset-value: 0;
        preview(v) => {
            root.preview-look(
                root.model.filter-id,
                root.model.filter-intensity,
                clamp(v, -100, 100) / 100,
                root.model.adjust-contrast,
                root.model.adjust-saturation,
                root.model.adjust-exposure,
                root.model.adjust-temperature);
        }
        commit(v) => {
            root.commit-adjust(
                clamp(v, -100, 100) / 100,
                root.model.adjust-contrast,
                root.model.adjust-saturation,
                root.model.adjust-exposure,
                root.model.adjust-temperature);
        }
        kf-visible: true;
        kf: root.brightness-sample.row;
        kf-can-toggle: root.playhead-inside;
        kf-toggle => {
            root.toggle-kf("look_adjust_brightness", root.brightness-sample.row.on-keyframe, root.brightness-sample.value);
        }
        kf-set-easing(e) => {
            root.ease-kf("look_adjust_brightness", e, root.brightness-sample.value);
        }
    }

    SliderRow {
        label: "Contrast";
        suffix: "%";
        value: root.contrast-sample.value * 100;
        minimum: -100;
        maximum: 100;
        step: 1;
        reset-value: 0;
        preview(v) => {
            root.preview-look(
                root.model.filter-id,
                root.model.filter-intensity,
                root.model.adjust-brightness,
                clamp(v, -100, 100) / 100,
                root.model.adjust-saturation,
                root.model.adjust-exposure,
                root.model.adjust-temperature);
        }
        commit(v) => {
            root.commit-adjust(
                root.model.adjust-brightness,
                clamp(v, -100, 100) / 100,
                root.model.adjust-saturation,
                root.model.adjust-exposure,
                root.model.adjust-temperature);
        }
        kf-visible: true;
        kf: root.contrast-sample.row;
        kf-can-toggle: root.playhead-inside;
        kf-toggle => {
            root.toggle-kf("look_adjust_contrast", root.contrast-sample.row.on-keyframe, root.contrast-sample.value);
        }
        kf-set-easing(e) => {
            root.ease-kf("look_adjust_contrast", e, root.contrast-sample.value);
        }
    }

    SliderRow {
        label: "Saturation";
        suffix: "%";
        value: root.saturation-sample.value * 100;
        minimum: -100;
        maximum: 100;
        step: 1;
        reset-value: 0;
        preview(v) => {
            root.preview-look(
                root.model.filter-id,
                root.model.filter-intensity,
                root.model.adjust-brightness,
                root.model.adjust-contrast,
                clamp(v, -100, 100) / 100,
                root.model.adjust-exposure,
                root.model.adjust-temperature);
        }
        commit(v) => {
            root.commit-adjust(
                root.model.adjust-brightness,
                root.model.adjust-contrast,
                clamp(v, -100, 100) / 100,
                root.model.adjust-exposure,
                root.model.adjust-temperature);
        }
        kf-visible: true;
        kf: root.saturation-sample.row;
        kf-can-toggle: root.playhead-inside;
        kf-toggle => {
            root.toggle-kf("look_adjust_saturation", root.saturation-sample.row.on-keyframe, root.saturation-sample.value);
        }
        kf-set-easing(e) => {
            root.ease-kf("look_adjust_saturation", e, root.saturation-sample.value);
        }
    }

    SliderRow {
        label: "Exposure";
        suffix: "%";
        value: root.exposure-sample.value * 100;
        minimum: -100;
        maximum: 100;
        step: 1;
        reset-value: 0;
        preview(v) => {
            root.preview-look(
                root.model.filter-id,
                root.model.filter-intensity,
                root.model.adjust-brightness,
                root.model.adjust-contrast,
                root.model.adjust-saturation,
                clamp(v, -100, 100) / 100,
                root.model.adjust-temperature);
        }
        commit(v) => {
            root.commit-adjust(
                root.model.adjust-brightness,
                root.model.adjust-contrast,
                root.model.adjust-saturation,
                clamp(v, -100, 100) / 100,
                root.model.adjust-temperature);
        }
        kf-visible: true;
        kf: root.exposure-sample.row;
        kf-can-toggle: root.playhead-inside;
        kf-toggle => {
            root.toggle-kf("look_adjust_exposure", root.exposure-sample.row.on-keyframe, root.exposure-sample.value);
        }
        kf-set-easing(e) => {
            root.ease-kf("look_adjust_exposure", e, root.exposure-sample.value);
        }
    }

    SliderRow {
        label: "Temperature";
        suffix: "%";
        value: root.temperature-sample.value * 100;
        minimum: -100;
        maximum: 100;
        step: 1;
        reset-value: 0;
        preview(v) => {
            root.preview-look(
                root.model.filter-id,
                root.model.filter-intensity,
                root.model.adjust-brightness,
                root.model.adjust-contrast,
                root.model.adjust-saturation,
                root.model.adjust-exposure,
                clamp(v, -100, 100) / 100);
        }
        commit(v) => {
            root.commit-adjust(
                root.model.adjust-brightness,
                root.model.adjust-contrast,
                root.model.adjust-saturation,
                root.model.adjust-exposure,
                clamp(v, -100, 100) / 100);
        }
        kf-visible: true;
        kf: root.temperature-sample.row;
        kf-can-toggle: root.playhead-inside;
        kf-toggle => {
            root.toggle-kf("look_adjust_temperature", root.temperature-sample.row.on-keyframe, root.temperature-sample.value);
        }
        kf-set-easing(e) => {
            root.ease-kf("look_adjust_temperature", e, root.temperature-sample.value);
        }
    }
}
