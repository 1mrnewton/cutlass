import {
    CutlassLineInput,
    CutlassScrollView,
    CutlassSlider,
    CutlassText,
    CutlassDropdown,
    CutlassColorSwatch,
} from "../../components/index.slint";
import {
    AppStore,
    EditorStore,
    TimelineStore,
    PreviewStore,
} from "../../store/index.slint";
import {
    InspectorBackend,
    ParamRowState,
    TransformSample,
} from "../../lib/inspector-backend.slint";
import { Clip, TextClipStyle } from "../../models/index.slint";
import { AppState } from "../../state.slint";
import { KeyframeControl } from "keyframe-control.slint";
import {
    InspectorDivider,
    InspectorTabHeader,
    SectionHeader,
    LabelCell,
    SliderRow,
} from "inspector-widgets.slint";
import { AnimationInspector } from "animation-inspector.slint";
import { TextStyleRows, IconButton, NumberBox } from "text-style-rows.slint";
import { TextTreatmentRows } from "text-treatment-rows.slint";
import { StylesInspector } from "styles-inspector.slint";

component PillTab inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    in property <bool> enabled: true;

    height: 30px;
    horizontal-stretch: 1;
    border-radius: AppStore.theme.metrics.radius.md;
    background: selected ? #444444 : (ta.has-hover && enabled ? #ffffff10 : #1b1b1b);
    opacity: enabled ? 1.0 : 0.45;

    CutlassText {
        width: 100%;
        height: 100%;
        text: root.label;
        style: AppStore.theme.typography.label;
        foreground: selected ? AppStore.theme.text.primary : AppStore.theme.text.secondary;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => {
            AppState.refocus-shortcuts();
        }
    }
}


component MultilineTextInput inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder-text;
    in property <string> accessibility-label: root.placeholder-text;
    in property <bool> enabled: true;
    in property <bool> read-only: false;
    out property <bool> has-focus: input.has-focus;

    callback edited(text: string);
    callback commit(text: string);
    callback cancelled();

    private property <length> pad: AppStore.theme.metrics.spacing.md;
    private property <string> focus-entry-text: root.text;

    height: 96px;
    min-width: 96px;
    horizontal-stretch: 1;
    border-radius: AppStore.theme.metrics.radius.md;
    border-width: 1px;
    border-color: input.has-focus ? AppStore.theme.accent.primary : #ffffff14;
    background: input.has-focus
        ? #202020
        : focus-area.has-hover && root.enabled
        ? #1e1e1e
        : #1a1a1a;
    opacity: root.enabled ? 1.0 : 0.55;
    clip: true;
    forward-focus: input;

    animate background {
        duration: 120ms;
        easing: ease-out;
    }
    animate border-color {
        duration: 120ms;
        easing: ease-out;
    }

    // Clicking the padding ring around the editor focuses it instead of
    // falling through to the panel's blur catcher.
    focus-area := TouchArea {
        enabled: root.enabled;
        mouse-cursor: MouseCursor.text;
        clicked => {
            input.focus();
        }
    }

    editor-scroll := CutlassScrollView {
        x: root.pad;
        y: root.pad;
        width: max(0px, root.width - 2 * root.pad);
        height: max(0px, root.height - 2 * root.pad);
        viewport-width: self.width;
        viewport-height: max(self.height, input.preferred-height);
        show-horizontal-scrollbar: false;
        show-vertical-scrollbar: input.preferred-height > self.height;
        interactive: false;

        input := TextInput {
            width: editor-scroll.width;
            height: max(editor-scroll.height, self.preferred-height);
            text <=> root.text;
            enabled: root.enabled;
            read-only: root.read-only;
            single-line: false;
            wrap: word-wrap;
            color: AppStore.theme.text.primary;
            font-size: AppStore.theme.typography.body.size;
            font-weight: AppStore.theme.typography.body.weight;
            selection-background-color: AppStore.theme.accent.primary.with-alpha(0.33);
            selection-foreground-color: AppStore.theme.text.primary;
            page-height: editor-scroll.height;
            accessible-label: root.accessibility-label;
            accessible-placeholder-text: root.placeholder-text;

            changed has-focus => {
                if (self.has-focus) {
                    root.focus-entry-text = root.text;
                } else if (root.text != root.focus-entry-text) {
                    root.commit(self.text);
                    root.focus-entry-text = root.text;
                }
            }

            edited => {
                root.edited(self.text);
            }

            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    root.text = root.focus-entry-text;
                    root.cancelled();
                    return accept;
                }
                reject
            }

            cursor-position-changed(cpos) => {
                if (cpos.y + editor-scroll.viewport-y < 8px) {
                    editor-scroll.viewport-y = min(0px, max(
                        editor-scroll.height - self.height,
                        -cpos.y + 8px,
                    ));
                } else if (cpos.y + editor-scroll.viewport-y > editor-scroll.height - 24px) {
                    editor-scroll.viewport-y = min(0px, max(
                        editor-scroll.height - self.height,
                        editor-scroll.height - cpos.y - 24px,
                    ));
                }
            }
        }
    }

    placeholder := CutlassText {
        x: root.pad;
        y: root.pad;
        width: max(0px, root.width - 2 * root.pad);
        height: AppStore.theme.typography.body.size + 6px;
        text: (root.text == "" && input.preedit-text == "") ? root.placeholder-text : "";
        style: AppStore.theme.typography.body;
        foreground: AppStore.theme.text.muted;
        vertical-alignment: TextVerticalAlignment.center;
        accessible-role: none;
    }
}

component PresetStyle inherits Rectangle {
    in property <string> label: "Aa";
    in property <color> foreground: #ffffff;
    in property <color> fill: #4a4a4a;
    in property <color> outline: transparent;
    in property <bool> selected: false;

    width: 50px;
    height: 50px;
    border-radius: AppStore.theme.metrics.radius.md;
    background: selected ? #ffffff12 : #ffffff0d;
    border-width: selected ? 2px : 0px;
    border-color: AppStore.theme.accent.primary;
    opacity: 0.65;

    Rectangle {
        x: 7px;
        y: 7px;
        width: parent.width - 14px;
        height: parent.height - 14px;
        border-radius: AppStore.theme.metrics.radius.md;
        background: root.fill;
    }

    Text {
        width: 100%;
        height: 100%;
        text: root.label;
        color: root.foreground;
        font-size: 24px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}



component PositionRow inherits HorizontalLayout {
    in property <string> label: "Position";
    in property <float> x-value;
    in property <float> y-value;
    // A vec2 param (position / anchor): one cluster keyframes both axes.
    in property <ParamRowState> kf;
    in property <bool> kf-can-toggle;

    callback commit-x(value: float);
    callback commit-y(value: float);
    callback kf-toggle();
    callback kf-set-easing(easing: int);

    spacing: AppStore.theme.metrics.spacing.md;
    height: 28px;
    vertical-stretch: 0;

    LabelCell {
        label: root.label;
    }

    NumberBox {
        prefix: "X";
        accessibility-label: root.label + " X";
        value: root.x-value;
        commit(v) => {
            root.commit-x(v);
        }
    }

    NumberBox {
        prefix: "Y";
        accessibility-label: root.label + " Y";
        value: root.y-value;
        commit(v) => {
            root.commit-y(v);
        }
    }

    Rectangle {
        horizontal-stretch: 1;
    }

    KeyframeControl {
        state: root.kf;
        can-toggle: root.kf-can-toggle;
        toggle => {
            root.kf-toggle();
        }
        jump(tick) => {
            TimelineStore.playhead-tick = tick;
        }
        set-easing(easing) => {
            root.kf-set-easing(easing);
        }
    }
}

component ToggleSwitch inherits Rectangle {
    in property <bool> checked: true;
    in property <bool> enabled: false;

    width: 42px;
    height: 22px;
    vertical-stretch: 0;
    border-radius: 11px;
    background: checked ? AppStore.theme.accent.primary : #ffffff1a;
    opacity: enabled ? 1.0 : 0.7;

    Rectangle {
        width: 16px;
        height: 16px;
        x: root.checked ? parent.width - self.width - 3px : 3px;
        y: 3px;
        border-radius: 8px;
        background: #f7f7f7;
    }
}

export component TextInspector inherits VerticalLayout {
    in property <string> track-id;
    // Named `model` — `clip` is a built-in boolean on Slint elements.
    in property <Clip> model;

    spacing: AppStore.theme.metrics.spacing.none;

    private property <string> bound-clip-id: model.id;
    private property <string> edit-text: model.text-content;
    // Scratch style used to build an edit: each control seeds it from the
    // authoritative `model.text-style`, overrides one field, and commits — so
    // concurrent fields are never stale and we never need to mirror the model.
    private property <TextClipStyle> style;
    private property <float> canvas-w: EditorStore.project.sequence.width / 1px;
    private property <float> canvas-h: EditorStore.project.sequence.height / 1px;
    // Playhead sample + per-property keyframe row state (keyframes roadmap
    // Phase 1): value rows track the rendered frame on animated clips.
    private property <TransformSample> sample: InspectorBackend.sample-transform(
        root.model, TimelineStore.playhead-tick);
    private property <bool> playhead-inside: TimelineStore.playhead-tick >= root.model.timeline-start.value
        && TimelineStore.playhead-tick < root.model.timeline-start.value + root.model.source-range.duration.value;
    private property <bool> live: PreviewStore.gesture-active
        && PreviewStore.gesture-clip == model.id
        && PreviewStore.gesture.valid;
    private property <float> pos-x: live ? PreviewStore.gesture.position-x : sample.position-x;
    private property <float> pos-y: live ? PreviewStore.gesture.position-y : sample.position-y;
    private property <int> selected-tab: 0;
    private property <float> anchor-x: live ? PreviewStore.gesture.anchor-x : sample.anchor-x;
    private property <float> anchor-y: live ? PreviewStore.gesture.anchor-y : sample.anchor-y;
    private property <float> scale-x: live ? PreviewStore.gesture.scale : sample.scale;
    private property <float> scale-y: live ? PreviewStore.gesture.scale-y : sample.scale-y;
    private property <float> rot-v: live ? PreviewStore.gesture.rotation : sample.rotation;
    private property <float> opacity-v: live ? PreviewStore.gesture.opacity : sample.opacity;

    changed bound-clip-id => {
        edit-text = model.text-content;
    }

    // Push the current text + scratch style through one undoable engine edit.
    // Guarded so a control firing with no net change (e.g. a slider released
    // without moving) doesn't spam the undo history.
    function commit-style() {
        if (root.edit-text != model.text-content || root.style != model.text-style) {
            InspectorBackend.set-text-generator(root.track-id, model.id, root.edit-text, root.style);
        }
    }

    // Seed the scratch style from the model, ready for a control to override a
    // single field before calling `commit-style()`.
    function begin-edit() {
        root.style = model.text-style;
    }

    // Release handler for a control that ran live previews (e.g. the font-size
    // slider): commit the scratch style if it differs, otherwise drop the
    // lingering preview override so it can't leak onto later renders.
    function commit-or-clear-style() {
        if (root.edit-text != model.text-content || root.style != model.text-style) {
            InspectorBackend.set-text-generator(root.track-id, model.id, root.edit-text, root.style);
        } else {
            InspectorBackend.clear-text-generator(TimelineStore.playhead-tick);
        }
    }

    // Push the scratch style through a live, uncommitted preview render at the
    // playhead — no history entry. Used while dragging a slider.
    function preview-style() {
        InspectorBackend.preview-text-generator(model.id, root.edit-text, root.style, TimelineStore.playhead-tick);
    }

    // Anchor edits compensate position so the rendered text stays put while
    // the pivot moves (same semantics as the preview anchor handle); position /
    // scale / rotation / opacity use `apply` directly.
    function apply-anchor(ax: float, ay: float, commit: bool) {
        let c = InspectorBackend.compensate-anchor-position(
            model,
            EditorStore.project.sequence,
            TimelineStore.playhead-tick,
            ax,
            ay,
            root.scale-x,
            root.scale-y,
            root.rot-v);
        root.apply(c.position-x, c.position-y, ax, ay, root.scale-x, root.scale-y, root.rot-v, root.opacity-v, commit);
    }

    // Text sheet keeps a single Scale row (uniform); transform inspector owns
    // per-axis. `sx`/`sy` still flow through so a live gizmo with split scale
    // does not flatten Y when nudging position from here.
    function apply(px: float, py: float, ax: float, ay: float, sx: float, sy: float, r: float, o: float, commit: bool) {
        if (commit) {
            // No-op against the playhead sample (what the rows display).
            if (px == sample.position-x
                && py == sample.position-y
                && ax == sample.anchor-x
                && ay == sample.anchor-y
                && sx == sample.scale
                && sy == sample.scale-y
                && r == sample.rotation
                && o == sample.opacity) {
                if (PreviewStore.gesture-active && PreviewStore.gesture-clip == model.id) {
                    EditorStore.on-preview-override-cleared(TimelineStore.playhead-tick);
                }
                PreviewStore.gesture-active = false;
                PreviewStore.gesture-commit-pending = false;
            } else {
                EditorStore.on-clip-transform-committed(
                    model.id, px, py, ax, ay, sx, sy, r, o, TimelineStore.playhead-tick);
                PreviewStore.gesture-commit-pending = true;
            }
        } else {
            // Same begin-then-override pairing as the canvas / transform
            // inspector — without it every slider tick pays a full re-render.
            if (!PreviewStore.gesture-active || PreviewStore.gesture-commit-pending
                || PreviewStore.gesture-clip != model.id) {
                EditorStore.on-preview-gesture-started(model.id, TimelineStore.playhead-tick);
            }
            PreviewStore.gesture-clip = model.id;
            PreviewStore.gesture = {
                valid: true,
                moved: true,
                position-x: px,
                position-y: py,
                anchor-x: ax,
                anchor-y: ay,
                scale: sx,
                scale-y: sy,
                rotation: r,
                opacity: o,
                snap-h: false,
                snap-v: false,
                guide-x: 0,
                guide-y: 0,
            };
            PreviewStore.gesture-commit-pending = false;
            PreviewStore.gesture-active = true;
            EditorStore.on-preview-transform-overridden(
                model.id, px, py, ax, ay, sx, sy, r, o, TimelineStore.playhead-tick);
        }
    }

    // Diamond toggle for one property: on a keyframe ⇒ remove it; anywhere
    // else ⇒ write one at the playhead holding the displayed (sampled)
    // value, so toggling never visibly changes the frame.
    function toggle-kf(param: string, on-keyframe: bool, vx: float, vy: float) {
        if (on-keyframe) {
            InspectorBackend.remove-param-keyframe(model.id, param, TimelineStore.playhead-tick);
        } else {
            InspectorBackend.set-param-keyframe(
                model.id, param, TimelineStore.playhead-tick, vx, vy, 0);
        }
    }

    // Re-ease the keyframe under the playhead: same tick + value, new
    // outgoing curve.
    function ease-kf(param: string, easing: int, vx: float, vy: float) {
        InspectorBackend.set-param-keyframe(
            model.id, param, TimelineStore.playhead-tick, vx, vy, easing);
    }

    InspectorTabHeader {
        tabs: ["Text", "Animation", "Text to speech"];
        tab-enabled: [true, true, false];
        selected: root.selected-tab;
        tab-selected(idx) => {
            root.selected-tab = idx;
        }
    }

    body-scroll := CutlassScrollView {
        vertical-stretch: 1;
        viewport-width: root.width;
        viewport-height: content.preferred-height;
        show-horizontal-scrollbar: false;
        interactive: false;

        // Same blur catcher for the property sheet: any click that no
        // control claims (labels, dividers, padding) unfocuses the active
        // text input, which commits its pending edit.
        TouchArea {
            x: 0;
            y: 0;
            width: body-scroll.width;
            height: max(body-scroll.height, content.preferred-height);
            clicked => {
                AppState.refocus-shortcuts();
            }
        }

        content := VerticalLayout {
            width: max(0px, root.width - AppStore.theme.scrollbar.size);
            spacing: AppStore.theme.metrics.spacing.lg;
            alignment: LayoutAlignment.start;
            padding: AppStore.theme.metrics.spacing.lg;

            if root.selected-tab == 1: AnimationInspector {
                model: root.model;
                text-only-combos: true;
            }

            if root.selected-tab == 0: VerticalLayout {
                spacing: AppStore.theme.metrics.spacing.lg;
                alignment: LayoutAlignment.start;

            HorizontalLayout {
                spacing: 1px;
                height: 30px;

                PillTab {
                    label: "Basic";
                    selected: true;
                }

                PillTab {
                    label: "Bubble";
                    enabled: false;
                }

                PillTab {
                    label: "Effects";
                    enabled: false;
                }
            }

            InspectorDivider { }

            MultilineTextInput {
                text: root.edit-text;
                placeholder-text: "Default text";
                accessibility-label: "Text content";

                // Typing only updates the local field; the engine edit (one undoable
                // history entry) commits on blur so undo isn't spammed per keystroke
                // and the projection republish can't fight the box.
                edited(new-text) => {
                    root.edit-text = new-text;
                }

                commit(new-text) => {
                    root.edit-text = new-text;
                    root.begin-edit();
                    root.commit-style();
                }
                cancelled => {
                    self.text = model.text-content;
                    root.edit-text = model.text-content;
                    AppState.refocus-shortcuts();
                }
            }

            TextStyleRows {
                track-id: root.track-id;
                model: root.model;
                edit-text: root.edit-text;
            }


            InspectorDivider { }

            CutlassText {
                text: "Preset style";
                style: AppStore.theme.typography.label;
                foreground: AppStore.theme.text.secondary;
            }

            CutlassScrollView {
                width: 100%;
                height: 50px;
                viewport-width: preset-styles.preferred-width;
                viewport-height: self.height;
                show-horizontal-scrollbar: false;
                show-vertical-scrollbar: false;
                interactive: false;

                preset-styles := HorizontalLayout {
                    spacing: AppStore.theme.metrics.spacing.md;

                    PresetStyle {
                        label: "/";
                        selected: true;
                        foreground: AppStore.theme.text.muted;
                        fill: #303030;
                    }

                    PresetStyle {
                        foreground: #ffffff;
                        fill: #111111;
                    }

                    PresetStyle {
                        foreground: #ffffff;
                        fill: #3f3f3f;
                    }

                    PresetStyle {
                        foreground: #f2f2f2;
                        fill: #8b6d4b;
                    }

                    PresetStyle {
                        foreground: #fff157;
                        fill: #1d1d1d;
                    }

                    PresetStyle {
                        foreground: #ff3b3b;
                        fill: #f5f5f5;
                    }

                    PresetStyle {
                        foreground: #2bbcff;
                        fill: #e7f5ff;
                    }

                    PresetStyle {
                        foreground: #00ef66;
                        fill: #151515;
                    }
                }
            }

            InspectorDivider { }

            SectionHeader {
                title: "Transform";
            }

            SliderRow {
                label: "Scale";
                suffix: "%";
                value: root.scale-x * 100;
                minimum: 1;
                maximum: 400;
                reset-value: 100;
                kf-visible: true;
                kf: root.sample.scale-row;
                kf-can-toggle: root.playhead-inside;
                preview(v) => {
                    let s = max(v, 1) / 100;
                    root.apply(root.pos-x, root.pos-y, root.anchor-x, root.anchor-y, s, s, root.rot-v, root.opacity-v, false);
                }
                commit(v) => {
                    let s = max(v, 1) / 100;
                    root.apply(root.pos-x, root.pos-y, root.anchor-x, root.anchor-y, s, s, root.rot-v, root.opacity-v, true);
                }
                kf-toggle => {
                    root.toggle-kf("scale", root.sample.scale-row.on-keyframe, root.scale-x, root.scale-y);
                }
                kf-set-easing(e) => {
                    root.ease-kf("scale", e, root.scale-x, root.scale-y);
                }
            }

            HorizontalLayout {
                spacing: AppStore.theme.metrics.spacing.md;

                LabelCell {
                    label: "Uniform scale";
                }

                Rectangle {
                    horizontal-stretch: 1;
                }

                ToggleSwitch {
                    checked: true;
                }
            }

            PositionRow {
                x-value: root.pos-x * root.canvas-w;
                y-value: root.pos-y * root.canvas-h;
                kf: root.sample.position-row;
                kf-can-toggle: root.playhead-inside;
                commit-x(v) => {
                    root.apply(v / root.canvas-w, root.pos-y, root.anchor-x, root.anchor-y, root.scale-x, root.scale-y, root.rot-v, root.opacity-v, true);
                }
                commit-y(v) => {
                    root.apply(root.pos-x, v / root.canvas-h, root.anchor-x, root.anchor-y, root.scale-x, root.scale-y, root.rot-v, root.opacity-v, true);
                }
                kf-toggle => {
                    root.toggle-kf("position", root.sample.position-row.on-keyframe, root.pos-x, root.pos-y);
                }
                kf-set-easing(e) => {
                    root.ease-kf("position", e, root.pos-x, root.pos-y);
                }
            }

            // Anchor as a percentage of the content box (50/50 = center); the
            // edit keeps pixels fixed via `apply-anchor` so moving the pivot
            // doesn't shift the title.
            PositionRow {
                label: "Anchor";
                x-value: root.anchor-x * 100;
                y-value: root.anchor-y * 100;
                kf: root.sample.anchor-row;
                kf-can-toggle: root.playhead-inside;
                commit-x(v) => {
                    root.apply-anchor(v / 100, root.anchor-y, true);
                }
                commit-y(v) => {
                    root.apply-anchor(root.anchor-x, v / 100, true);
                }
                kf-toggle => {
                    root.toggle-kf("anchor", root.sample.anchor-row.on-keyframe, root.anchor-x, root.anchor-y);
                }
                kf-set-easing(e) => {
                    root.ease-kf("anchor", e, root.anchor-x, root.anchor-y);
                }
            }

            SliderRow {
                label: "Plane rotation";
                suffix: "deg";
                value: root.rot-v;
                minimum: -180;
                maximum: 180;
                reset-value: 0;
                kf-visible: true;
                kf: root.sample.rotation-row;
                kf-can-toggle: root.playhead-inside;
                preview(v) => {
                    root.apply(root.pos-x, root.pos-y, root.anchor-x, root.anchor-y, root.scale-x, root.scale-y, v, root.opacity-v, false);
                }
                commit(v) => {
                    root.apply(root.pos-x, root.pos-y, root.anchor-x, root.anchor-y, root.scale-x, root.scale-y, v, root.opacity-v, true);
                }
                kf-toggle => {
                    root.toggle-kf("rotation", root.sample.rotation-row.on-keyframe, root.rot-v, 0);
                }
                kf-set-easing(e) => {
                    root.ease-kf("rotation", e, root.rot-v, 0);
                }
            }

            HorizontalLayout {
                spacing: AppStore.theme.metrics.spacing.sm;
                opacity: 0.55;

                IconButton {
                    label: "|<";
                    selected: true;
                }

                IconButton {
                    label: "+";
                }

                IconButton {
                    label: ">|";
                }

                IconButton {
                    label: "T";
                }

                IconButton {
                    label: "B";
                }

                Rectangle {
                    horizontal-stretch: 1;
                }
            }

            InspectorDivider { }

            SectionHeader {
                title: "Blend";
                active: true;
                checkable: true;
            }

            SliderRow {
                label: "Opacity";
                suffix: "%";
                value: root.opacity-v * 100;
                minimum: 0;
                maximum: 100;
                reset-value: 100;
                kf-visible: true;
                kf: root.sample.opacity-row;
                kf-can-toggle: root.playhead-inside;
                preview(v) => {
                    root.apply(root.pos-x, root.pos-y, root.anchor-x, root.anchor-y, root.scale-x, root.scale-y, root.rot-v, clamp(v, 0, 100) / 100, false);
                }
                commit(v) => {
                    root.apply(root.pos-x, root.pos-y, root.anchor-x, root.anchor-y, root.scale-x, root.scale-y, root.rot-v, clamp(v, 0, 100) / 100, true);
                }
                kf-toggle => {
                    root.toggle-kf("opacity", root.sample.opacity-row.on-keyframe, root.opacity-v, 0);
                }
                kf-set-easing(e) => {
                    root.ease-kf("opacity", e, root.opacity-v, 0);
                }
            }


            TextTreatmentRows {
                track-id: root.track-id;
                model: root.model;
                edit-text: root.edit-text;
            }

            InspectorDivider { }

            StylesInspector {
                model: root.model;
            }

            HorizontalLayout {
                Rectangle {
                    horizontal-stretch: 1;
                }

                Rectangle {
                    height: 28px;
                    width: 116px;
                    border-radius: AppStore.theme.metrics.radius.sm;
                    background: AppStore.theme.accent.primary;
                    opacity: 0.45;

                    CutlassText {
                        width: 100%;
                        height: 100%;
                        text: "Save as preset";
                        style: AppStore.theme.typography.label;
                        foreground: #0A0A0A;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
            }
        }
    }
}
