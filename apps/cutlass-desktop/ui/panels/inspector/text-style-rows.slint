// Typography style rows extracted from text-inspector.slint (pure move).

import {
    CutlassLineInput,
    CutlassText,
    CutlassDropdown,
    CutlassColorSwatch,
    CutlassSlider,
} from "../../components/index.slint";
import {
    AppStore,
    EditorStore,
    TimelineStore,
} from "../../store/index.slint";
import { InspectorBackend, ScalarParamSample } from "../../lib/inspector-backend.slint";
import { Clip, TextClipStyle } from "../../models/index.slint";
import { AppState } from "../../state.slint";
import { LabelCell, SliderRow } from "inspector-widgets.slint";
import { KeyframeControl } from "keyframe-control.slint";

export component IconButton inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> show-icon: false;
    in property <bool> selected: false;
    in property <bool> enabled: false;

    callback clicked();

    width: show-icon ? 32px : max(32px, text.preferred-width + 2 * AppStore.theme.metrics.spacing.sm);
    height: 28px;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: selected
        ? #4a4a4a
        : (ta.has-hover && enabled ? #ffffff1c : #ffffff10);
    opacity: enabled ? 1.0 : 0.45;

    Image {
        width: 16px;
        height: 16px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: root.icon;
        image-fit: contain;
        colorize: AppStore.theme.text.primary;
        visible: show-icon;
    }

    text := CutlassText {
        width: 100%;
        height: 100%;
        text: root.label;
        style: AppStore.theme.typography.label;
        foreground: AppStore.theme.text.primary;
        horizontal-alignment: center;
        vertical-alignment: center;
        visible: !show-icon;
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
            AppState.refocus-shortcuts();
        }
    }
}


export component NumberBox inherits Rectangle {
    in property <string> prefix;
    in property <image> prefix-icon;
    in property <bool> show-prefix-icon: false;
    in property <float> value;
    in property <string> accessibility-label: root.prefix + " value";
    callback commit(value: float);

    width: 92px;
    height: 28px;
    vertical-stretch: 0;

    changed value => {
        if !field.has-focus {
            field.text = Math.round(root.value) + "";
        }
    }

    field := CutlassLineInput {
        width: 100%;
        minimum-field-width: 92px;
        height: parent.height;
        text-padding-left: 24px;
        text-padding-right: AppStore.theme.metrics.spacing.xs;
        horizontal-alignment: TextHorizontalAlignment.right;
        accessibility-label: root.accessibility-label;
        commit-on-blur: true;
        revert-on-escape: true;
        text: Math.round(root.value) + "";

        accepted(entered) => {
            if (entered.is-float()) {
                root.commit(entered.to-float());
            }
            self.text = Math.round(root.value) + "";
        }
        enter-accepted(_) => {
            AppState.refocus-shortcuts();
        }
        blurred(_, changed) => {
            if !changed {
                self.text = Math.round(root.value) + "";
            }
        }
        cancelled => {
            self.text = Math.round(root.value) + "";
            AppState.refocus-shortcuts();
        }
    }

    Image {
        x: AppStore.theme.metrics.spacing.sm;
        y: (parent.height - self.height) / 2;
        width: 14px;
        height: 14px;
        source: root.prefix-icon;
        image-fit: contain;
        colorize: AppStore.theme.text.muted;
        visible: show-prefix-icon;
    }

    CutlassText {
        x: AppStore.theme.metrics.spacing.sm;
        width: 16px;
        height: 100%;
        text: root.prefix;
        style: AppStore.theme.typography.label;
        foreground: AppStore.theme.text.muted;
        vertical-alignment: TextVerticalAlignment.center;
        accessible-role: none;
        visible: !show-prefix-icon;
    }
}

export component TextStyleRows inherits VerticalLayout {
    in property <string> track-id;
    in property <Clip> model;
    // Content text is owned by the parent editor; style commits preserve it.
    in property <string> edit-text;

    spacing: AppStore.theme.metrics.spacing.lg;
    alignment: LayoutAlignment.start;

    private property <TextClipStyle> style;
    private property <bool> playhead-inside: TimelineStore.playhead-tick >= model.timeline-start.value
        && TimelineStore.playhead-tick < model.timeline-start.value + model.source-range.duration.value;
    private property <ScalarParamSample> size-sample: InspectorBackend.sample-scalar-param(
        model, "text_size", TimelineStore.playhead-tick);
    private property <ScalarParamSample> letter-spacing-sample: InspectorBackend.sample-scalar-param(
        model, "text_letter_spacing", TimelineStore.playhead-tick);
    private property <ScalarParamSample> line-spacing-sample: InspectorBackend.sample-scalar-param(
        model, "text_line_spacing", TimelineStore.playhead-tick);

    function toggle-kf(param: string, on-keyframe: bool, value: float) {
        if (on-keyframe) {
            InspectorBackend.remove-param-keyframe(model.id, param, TimelineStore.playhead-tick);
        } else {
            InspectorBackend.set-param-keyframe(model.id, param, TimelineStore.playhead-tick, value, 0, 0);
        }
    }

    function ease-kf(param: string, easing: int, value: float) {
        InspectorBackend.set-param-keyframe(model.id, param, TimelineStore.playhead-tick, value, 0, easing);
    }

    function commit-style() {
        if (root.edit-text != model.text-content || root.style != model.text-style) {
            InspectorBackend.set-text-generator(root.track-id, model.id, root.edit-text, root.style);
        }
    }

    function begin-edit() {
        root.style = model.text-style;
    }

    function commit-or-clear-style() {
        if (root.edit-text != model.text-content || root.style != model.text-style) {
            InspectorBackend.set-text-generator(root.track-id, model.id, root.edit-text, root.style);
        } else {
            InspectorBackend.clear-text-generator(TimelineStore.playhead-tick);
        }
    }

    function preview-style() {
        InspectorBackend.preview-text-generator(model.id, root.edit-text, root.style, TimelineStore.playhead-tick);
    }

        HorizontalLayout {
            spacing: AppStore.theme.metrics.spacing.md;

            LabelCell {
                label: "Font";
            }

            font-drop := CutlassDropdown {
                searchable: true;
                placeholder: "System";
                current: model.text-style.font;
                items: InspectorBackend.filter-fonts(self.query, InspectorBackend.font-families);
                selected(value) => {
                    root.begin-edit();
                    root.style.font = value;
                    root.commit-style();
                }
            }
        }

        font-size-row := HorizontalLayout {
            property <float> model-size: root.size-sample.value;
            spacing: AppStore.theme.metrics.spacing.md;

            changed model-size => {
                if !size-num.has-focus {
                    size-num.text = Math.round(self.model-size) + "";
                }
            }

            LabelCell {
                label: "Font size";
            }

            CutlassSlider {
                horizontal-stretch: 1;
                height: 28px;
                vertical-stretch: 0;
                minimum: 8;
                maximum: 240;
                value: clamp(root.size-sample.value, 8, 240);
                changed(v) => {
                    // Track the live value while dragging; the model size
                    // only changes on commit (release).
                    size-num.text = Math.round(v) + "";
                    // Live-preview the new size on the canvas without
                    // committing — seed the scratch style and override size.
                    root.begin-edit();
                    root.style.size = v;
                    root.preview-style();
                }
                released(v) => {
                    root.begin-edit();
                    root.style.size = v;
                    root.commit-or-clear-style();
                }
            }

            size-num := CutlassLineInput {
                width: 56px;
                minimum-field-width: 56px;
                height: 28px;
                vertical-stretch: 0;
                horizontal-alignment: TextHorizontalAlignment.right;
                accessibility-label: "Font size";
                commit-on-blur: true;
                revert-on-escape: true;
                text: Math.round(root.size-sample.value) + "";
                accepted(entered) => {
                    if (entered.is-float()) {
                        root.begin-edit();
                        root.style.size = clamp(entered.to-float(), 8, 240);
                        root.commit-style();
                    }
                    self.text = Math.round(model.text-style.size) + "";
                }
                enter-accepted(_) => {
                    AppState.refocus-shortcuts();
                }
                blurred(_, changed) => {
                    if !changed {
                        self.text = Math.round(model.text-style.size) + "";
                    }
                }
                cancelled => {
                    self.text = Math.round(model.text-style.size) + "";
                    AppState.refocus-shortcuts();
                }
            }

            KeyframeControl {
                state: root.size-sample.row;
                can-toggle: root.playhead-inside;
                toggle => {
                    root.toggle-kf("text_size", root.size-sample.row.on-keyframe, root.size-sample.value);
                }
                jump(tick) => { TimelineStore.playhead-tick = tick; }
                set-easing(easing) => {
                    root.ease-kf("text_size", easing, root.size-sample.value);
                }
            }
        }

        HorizontalLayout {
            spacing: AppStore.theme.metrics.spacing.md;

            LabelCell {
                label: "Pattern";
            }

            IconButton {
                label: "Bold";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/bold.svg");
                enabled: true;
                selected: model.text-style.bold;
                clicked => {
                    root.begin-edit();
                    root.style.bold = !model.text-style.bold;
                    root.commit-style();
                }
            }

            IconButton {
                label: "Underline";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/underline.svg");
                enabled: true;
                selected: model.text-style.underline;
                clicked => {
                    root.begin-edit();
                    root.style.underline = !model.text-style.underline;
                    root.commit-style();
                }
            }

            IconButton {
                label: "Italic";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/italic.svg");
                enabled: true;
                selected: model.text-style.italic;
                clicked => {
                    root.begin-edit();
                    root.style.italic = !model.text-style.italic;
                    root.commit-style();
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        HorizontalLayout {
            spacing: AppStore.theme.metrics.spacing.md;

            LabelCell {
                label: "Case";
            }

            IconButton {
                label: "Uppercase";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/case-upper.svg");
                enabled: true;
                selected: model.text-style.case == 1;
                clicked => {
                    root.begin-edit();
                    root.style.case = model.text-style.case == 1 ? 0 : 1;
                    root.commit-style();
                }
            }

            IconButton {
                label: "Lowercase";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/case-lower.svg");
                enabled: true;
                selected: model.text-style.case == 2;
                clicked => {
                    root.begin-edit();
                    root.style.case = model.text-style.case == 2 ? 0 : 2;
                    root.commit-style();
                }
            }

            IconButton {
                label: "Title case";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/case-sensitive.svg");
                enabled: true;
                selected: model.text-style.case == 3;
                clicked => {
                    root.begin-edit();
                    root.style.case = model.text-style.case == 3 ? 0 : 3;
                    root.commit-style();
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        HorizontalLayout {
            spacing: AppStore.theme.metrics.spacing.md;

            LabelCell {
                label: "Color";
            }

            CutlassColorSwatch {
                value: model.text-style.fill;
                preview(c) => {
                    root.begin-edit();
                    root.style.fill = c;
                    root.preview-style();
                }
                changed(c) => {
                    root.begin-edit();
                    root.style.fill = c;
                    root.commit-or-clear-style();
                }
                cancelled => {
                    InspectorBackend.clear-text-generator(TimelineStore.playhead-tick);
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        // Letter / line spacing: live SliderRows through the generic
        // ClipParam override lane (preview-param → ParamOverride). Release
        // commits one edit (constant or playhead keyframe) then clears —
        // same ordering as volume/pan.
        SliderRow {
            label: "Letter";
            suffix: "px";
            value: root.letter-spacing-sample.value;
            minimum: -100;
            maximum: 200;
            reset-value: 0;
            kf-visible: true;
            kf: root.letter-spacing-sample.row;
            kf-can-toggle: root.playhead-inside;
            preview(v) => {
                InspectorBackend.preview-param(
                    model.id, "text_letter_spacing", v, 0, TimelineStore.playhead-tick);
            }
            commit(v) => {
                if (root.letter-spacing-sample.row.animated) {
                    if (root.playhead-inside) {
                        InspectorBackend.set-param-keyframe(
                            model.id, "text_letter_spacing", TimelineStore.playhead-tick, v, 0, 0);
                    } else {
                        InspectorBackend.clear-param-override(
                            model.id, TimelineStore.playhead-tick);
                    }
                } else {
                    InspectorBackend.set-param-constant(model.id, "text_letter_spacing", v, 0);
                }
            }
            cancelled => {
                InspectorBackend.clear-param-override(
                    model.id, TimelineStore.playhead-tick);
            }
            kf-toggle => {
                root.toggle-kf(
                    "text_letter_spacing",
                    root.letter-spacing-sample.row.on-keyframe,
                    root.letter-spacing-sample.value);
            }
            kf-set-easing(easing) => {
                root.ease-kf("text_letter_spacing", easing, root.letter-spacing-sample.value);
            }
        }

        SliderRow {
            label: "Line";
            suffix: "%";
            value: root.line-spacing-sample.value * 100;
            minimum: 50;
            maximum: 300;
            reset-value: 120;
            kf-visible: true;
            kf: root.line-spacing-sample.row;
            kf-can-toggle: root.playhead-inside;
            preview(v) => {
                InspectorBackend.preview-param(
                    model.id, "text_line_spacing", max(v, 10) / 100, 0, TimelineStore.playhead-tick);
            }
            commit(v) => {
                if (root.line-spacing-sample.row.animated) {
                    if (root.playhead-inside) {
                        InspectorBackend.set-param-keyframe(
                            model.id, "text_line_spacing", TimelineStore.playhead-tick,
                            max(v, 10) / 100, 0, 0);
                    } else {
                        InspectorBackend.clear-param-override(
                            model.id, TimelineStore.playhead-tick);
                    }
                } else {
                    InspectorBackend.set-param-constant(
                        model.id, "text_line_spacing", max(v, 10) / 100, 0);
                }
            }
            cancelled => {
                InspectorBackend.clear-param-override(
                    model.id, TimelineStore.playhead-tick);
            }
            kf-toggle => {
                root.toggle-kf(
                    "text_line_spacing",
                    root.line-spacing-sample.row.on-keyframe,
                    root.line-spacing-sample.value);
            }
            kf-set-easing(easing) => {
                root.ease-kf("text_line_spacing", easing, root.line-spacing-sample.value);
            }
        }

        HorizontalLayout {
            spacing: AppStore.theme.metrics.spacing.md;

            LabelCell {
                label: "Alignment";
            }

            IconButton {
                label: "Align left";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/align-left.svg");
                enabled: true;
                selected: model.text-style.align-h == 0;
                clicked => {
                    root.begin-edit();
                    root.style.align-h = 0;
                    root.commit-style();
                }
            }

            IconButton {
                label: "Align center";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/align-center.svg");
                enabled: true;
                selected: model.text-style.align-h == 1;
                clicked => {
                    root.begin-edit();
                    root.style.align-h = 1;
                    root.commit-style();
                }
            }

            IconButton {
                label: "Align right";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/align-right.svg");
                enabled: true;
                selected: model.text-style.align-h == 2;
                clicked => {
                    root.begin-edit();
                    root.style.align-h = 2;
                    root.commit-style();
                }
            }

            IconButton {
                label: "Align top";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/align-start-vertical.svg");
                enabled: true;
                selected: model.text-style.align-v == 0;
                clicked => {
                    root.begin-edit();
                    root.style.align-v = 0;
                    root.commit-style();
                }
            }

            IconButton {
                label: "Align middle";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/align-center-vertical.svg");
                enabled: true;
                selected: model.text-style.align-v == 1;
                clicked => {
                    root.begin-edit();
                    root.style.align-v = 1;
                    root.commit-style();
                }
            }

            IconButton {
                label: "Align bottom";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/align-end-vertical.svg");
                enabled: true;
                selected: model.text-style.align-v == 2;
                clicked => {
                    root.begin-edit();
                    root.style.align-v = 2;
                    root.commit-style();
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        HorizontalLayout {
            spacing: AppStore.theme.metrics.spacing.md;

            LabelCell {
                label: "Wrap";
            }

            IconButton {
                label: "Wrap";
                show-icon: true;
                icon: @image-url("../../../../../assets/icon/text/wrap-text.svg");
                enabled: true;
                selected: model.text-style.wrap;
                clicked => {
                    root.begin-edit();
                    root.style.wrap = !model.text-style.wrap;
                    root.commit-style();
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }
}
