// Text stroke / background / glow / shadow treatments (pure move from text-inspector).

import {
    CutlassText,
    CutlassColorSwatch,
} from "../../components/index.slint";
import {
    AppStore,
    TimelineStore,
} from "../../store/index.slint";
import { InspectorBackend, ScalarParamSample } from "../../lib/inspector-backend.slint";
import { Clip, TextClipStyle } from "../../models/index.slint";
import {
    InspectorDivider,
    SectionHeader,
    LabelCell,
    SliderRow,
} from "inspector-widgets.slint";

export component FakeField inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: false;

    height: 28px;
    horizontal-stretch: 1;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: #1a1a1a;
    opacity: enabled ? 1.0 : 0.45;

    CutlassText {
        x: AppStore.theme.metrics.spacing.sm;
        width: parent.width - 2 * AppStore.theme.metrics.spacing.sm;
        height: parent.height;
        text: root.text;
        style: AppStore.theme.typography.body;
        foreground: AppStore.theme.text.secondary;
        vertical-alignment: TextVerticalAlignment.center;
        overflow: TextOverflow.elide;
    }
}

export component DisabledPropertyRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;

    spacing: AppStore.theme.metrics.spacing.md;
    height: 28px;
    vertical-stretch: 0;
    opacity: 0.55;

    LabelCell {
        label: root.label;
    }

    FakeField {
        text: root.value;
    }
}

export component DisabledEffectCard inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;

    width: 78px;
    height: 78px;
    border-radius: AppStore.theme.metrics.radius.md;
    background: #ffffff0a;
    border-width: selected ? 2px : 0px;
    border-color: AppStore.theme.accent.primary;
    opacity: 0.45;

    CutlassText {
        width: 100%;
        height: 100%;
        text: root.label;
        style: AppStore.theme.typography.heading-md;
        foreground: AppStore.theme.text.secondary;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// CapCut-inspired property sheet for text / title clips. Style treatments
// (stroke / background / shadow) persist and render; Glow is still a stub.


export component TextTreatmentRows inherits VerticalLayout {
    in property <string> track-id;
    in property <Clip> model;
    in property <string> edit-text;

    spacing: AppStore.theme.metrics.spacing.lg;
    alignment: LayoutAlignment.start;

    private property <TextClipStyle> style;
    private property <bool> playhead-inside: TimelineStore.playhead-tick >= model.timeline-start.value
        && TimelineStore.playhead-tick < model.timeline-start.value + model.source-range.duration.value;
    private property <ScalarParamSample> stroke-width-sample: InspectorBackend.sample-scalar-param(
        model, "text_stroke_width", TimelineStore.playhead-tick);
    private property <ScalarParamSample> shadow-blur-sample: InspectorBackend.sample-scalar-param(
        model, "text_shadow_blur", TimelineStore.playhead-tick);
    private property <ScalarParamSample> shadow-distance-sample: InspectorBackend.sample-scalar-param(
        model, "text_shadow_distance", TimelineStore.playhead-tick);

    function toggle-kf(param: string, on-keyframe: bool, value: float) {
        if (on-keyframe) {
            InspectorBackend.remove-param-keyframe(model.id, param, TimelineStore.playhead-tick);
        } else {
            InspectorBackend.set-param-keyframe(model.id, param, TimelineStore.playhead-tick, value, 0, 0);
        }
    }

    function ease-kf(param: string, easing: int, value: float) {
        InspectorBackend.set-param-keyframe(model.id, param, TimelineStore.playhead-tick, value, 0, easing);
    }

    function commit-style() {
        if (root.edit-text != model.text-content || root.style != model.text-style) {
            InspectorBackend.set-text-generator(root.track-id, model.id, root.edit-text, root.style);
        }
    }

    function begin-edit() {
        root.style = model.text-style;
    }

    function commit-or-clear-style() {
        if (root.edit-text != model.text-content || root.style != model.text-style) {
            InspectorBackend.set-text-generator(root.track-id, model.id, root.edit-text, root.style);
        } else {
            InspectorBackend.clear-text-generator(TimelineStore.playhead-tick);
        }
    }

    function preview-style() {
        InspectorBackend.preview-text-generator(model.id, root.edit-text, root.style, TimelineStore.playhead-tick);
    }

        InspectorDivider { }

        SectionHeader {
            title: "Stroke";
            active: model.text-style.stroke-enabled;
            checkable: true;
            interactive: true;
            toggled => {
                root.begin-edit();
                root.style.stroke-enabled = !model.text-style.stroke-enabled;
                root.commit-style();
            }
            reset => {
                root.begin-edit();
                root.style.stroke-enabled = false;
                root.commit-style();
            }
        }

        if model.text-style.stroke-enabled: HorizontalLayout {
            spacing: AppStore.theme.metrics.spacing.md;

            LabelCell {
                label: "Color";
            }

            CutlassColorSwatch {
                value: model.text-style.stroke-color;
                changed(c) => {
                    root.begin-edit();
                    root.style.stroke-color = c;
                    root.commit-style();
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        if model.text-style.stroke-enabled: SliderRow {
            label: "Thickness";
            suffix: "";
            value: root.stroke-width-sample.value;
            minimum: 0;
            maximum: 40;
            reset-value: 6;
            preview(v) => {
                root.begin-edit();
                root.style.stroke-width = clamp(v, 0, 40);
                root.preview-style();
            }
            commit(v) => {
                root.begin-edit();
                root.style.stroke-width = clamp(v, 0, 40);
                root.commit-or-clear-style();
            }
            kf-visible: true;
            kf: root.stroke-width-sample.row;
            kf-can-toggle: root.playhead-inside;
            kf-toggle => {
                root.toggle-kf("text_stroke_width", root.stroke-width-sample.row.on-keyframe, root.stroke-width-sample.value);
            }
            kf-set-easing(e) => {
                root.ease-kf("text_stroke_width", e, root.stroke-width-sample.value);
            }
        }

        InspectorDivider { }

        SectionHeader {
            title: "Background";
            active: model.text-style.background-enabled;
            checkable: true;
            interactive: true;
            toggled => {
                root.begin-edit();
                root.style.background-enabled = !model.text-style.background-enabled;
                root.commit-style();
            }
            reset => {
                root.begin-edit();
                root.style.background-enabled = false;
                root.commit-style();
            }
        }

        if model.text-style.background-enabled: HorizontalLayout {
            spacing: AppStore.theme.metrics.spacing.md;

            LabelCell {
                label: "Color";
            }

            CutlassColorSwatch {
                value: model.text-style.background-color;
                changed(c) => {
                    root.begin-edit();
                    root.style.background-color = c;
                    root.commit-style();
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        if model.text-style.background-enabled: SliderRow {
            label: "Opacity";
            suffix: "%";
            value: model.text-style.background-opacity * 100;
            minimum: 0;
            maximum: 100;
            reset-value: 100;
            preview(v) => {
                root.begin-edit();
                root.style.background-opacity = clamp(v, 0, 100) / 100;
                root.preview-style();
            }
            commit(v) => {
                root.begin-edit();
                root.style.background-opacity = clamp(v, 0, 100) / 100;
                root.commit-or-clear-style();
            }
        }

        if model.text-style.background-enabled: SliderRow {
            label: "Rounded";
            suffix: "%";
            value: model.text-style.background-radius * 100;
            minimum: 0;
            maximum: 100;
            reset-value: 0;
            preview(v) => {
                root.begin-edit();
                root.style.background-radius = clamp(v, 0, 100) / 100;
                root.preview-style();
            }
            commit(v) => {
                root.begin-edit();
                root.style.background-radius = clamp(v, 0, 100) / 100;
                root.commit-or-clear-style();
            }
        }

        InspectorDivider { }

        SectionHeader {
            title: "Glow";
            active: false;
            checkable: true;
        }

        HorizontalLayout {
            spacing: AppStore.theme.metrics.spacing.md;

            DisabledEffectCard {
                label: "Aa";
                selected: true;
            }

            DisabledEffectCard {
                label: "Aa";
            }
        }

        DisabledPropertyRow {
            label: "Intensity";
            value: "30";
        }

        DisabledPropertyRow {
            label: "Range";
            value: "20";
        }

        InspectorDivider { }

        SectionHeader {
            title: "Shadow";
            active: model.text-style.shadow-enabled;
            checkable: true;
            interactive: true;
            toggled => {
                root.begin-edit();
                root.style.shadow-enabled = !model.text-style.shadow-enabled;
                root.commit-style();
            }
            reset => {
                root.begin-edit();
                root.style.shadow-enabled = false;
                root.commit-style();
            }
        }

        if model.text-style.shadow-enabled: HorizontalLayout {
            spacing: AppStore.theme.metrics.spacing.md;

            LabelCell {
                label: "Color";
            }

            CutlassColorSwatch {
                value: model.text-style.shadow-color;
                changed(c) => {
                    root.begin-edit();
                    root.style.shadow-color = c;
                    root.commit-style();
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        if model.text-style.shadow-enabled: SliderRow {
            label: "Opacity";
            suffix: "%";
            value: model.text-style.shadow-opacity * 100;
            minimum: 0;
            maximum: 100;
            reset-value: 90;
            preview(v) => {
                root.begin-edit();
                root.style.shadow-opacity = clamp(v, 0, 100) / 100;
                root.preview-style();
            }
            commit(v) => {
                root.begin-edit();
                root.style.shadow-opacity = clamp(v, 0, 100) / 100;
                root.commit-or-clear-style();
            }
        }

        if model.text-style.shadow-enabled: SliderRow {
            label: "Blur";
            suffix: "%";
            value: root.shadow-blur-sample.value * 100;
            minimum: 0;
            maximum: 100;
            reset-value: 15;
            preview(v) => {
                root.begin-edit();
                root.style.shadow-blur = clamp(v, 0, 100) / 100;
                root.preview-style();
            }
            commit(v) => {
                root.begin-edit();
                root.style.shadow-blur = clamp(v, 0, 100) / 100;
                root.commit-or-clear-style();
            }
            kf-visible: true;
            kf: root.shadow-blur-sample.row;
            kf-can-toggle: root.playhead-inside;
            kf-toggle => {
                root.toggle-kf("text_shadow_blur", root.shadow-blur-sample.row.on-keyframe, root.shadow-blur-sample.value);
            }
            kf-set-easing(e) => {
                root.ease-kf("text_shadow_blur", e, root.shadow-blur-sample.value);
            }
        }

        if model.text-style.shadow-enabled: SliderRow {
            label: "Distance";
            suffix: "";
            value: root.shadow-distance-sample.value;
            minimum: 0;
            maximum: 50;
            reset-value: 5;
            preview(v) => {
                root.begin-edit();
                root.style.shadow-distance = clamp(v, 0, 50);
                root.preview-style();
            }
            commit(v) => {
                root.begin-edit();
                root.style.shadow-distance = clamp(v, 0, 50);
                root.commit-or-clear-style();
            }
            kf-visible: true;
            kf: root.shadow-distance-sample.row;
            kf-can-toggle: root.playhead-inside;
            kf-toggle => {
                root.toggle-kf("text_shadow_distance", root.shadow-distance-sample.row.on-keyframe, root.shadow-distance-sample.value);
            }
            kf-set-easing(e) => {
                root.ease-kf("text_shadow_distance", e, root.shadow-distance-sample.value);
            }
        }
}
