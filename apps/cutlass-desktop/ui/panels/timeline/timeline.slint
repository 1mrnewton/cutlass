import {
    CutlassText,
    HorizontalDivider,
    PanelBase,
    CutlassScrollBar,
    VerticalDivider,
} from "../../components/index.slint";
import { AppStore, EditorStore, TimelineStore, TimelineActions } from "../../store/index.slint";
import { Toolbar } from "toolbar.slint";
import { TrackLane } from "track-lane.slint";
import { TrackHead } from "track-head.slint";
import { Ruler } from "ruler.slint";
import { ClipView } from "clip.slint";
import { TimelineViewState } from "state.slint";
import { Sequence } from "../../models/index.slint";
import { TimelineLib } from "../../lib/timeline-lib.slint";
import { DragBackend, SnapResult, ClipDragResolution, ClipTrimResolution, LibraryDropResolution, GroupDragResolution, TransitionJunctionResolution } from "../../lib/drag-backend.slint";
import { EffectsBackend } from "../../lib/effects-backend.slint";
import { SelectionBackend } from "../../lib/selection-backend.slint";
import { AppState } from "../../state.slint";
import { LaneOverlays } from "lane-overlays.slint";



component ForceHeadSpace inherits Rectangle {

    height: TimelineActions.track-lane-height();

    background: transparent;
}

// CapCut's drag readout bubble: a dark pill that hovers above the dragged
// edge/clip. Shared by trims (duration + signed delta) and moves/library
// drops (landing timecode). The caller positions it (usually centered on an
// edge via `x: edge - self.width / 2`).

export component TimelinePanel inherits PanelBase {

    // The drag's TouchArea holds the pointer grab, so we never receive pointer
    // events here — instead hit-test the cursor in window space.
    private property <bool> library-cursor-inside:
        AppState.library-drag-cursor-x >= self.absolute-position.x
        && AppState.library-drag-cursor-x < self.absolute-position.x + self.width
        && AppState.library-drag-cursor-y >= self.absolute-position.y
        && AppState.library-drag-cursor-y < self.absolute-position.y + self.height;

    // True while a library tile is being dragged and the cursor is inside this
    // panel.
    private property <bool> library-drag-over:
        AppState.library-drag-active && self.library-cursor-inside;

    // Mirror into AppState so the ghost can react.
    changed library-drag-over => {
        AppState.library-drag-over-timeline = self.library-drag-over;
    }

    private property <bool> transition-cursor-inside:
        AppState.transition-drag-cursor-x >= self.absolute-position.x
        && AppState.transition-drag-cursor-x < self.absolute-position.x + self.width
        && AppState.transition-drag-cursor-y >= self.absolute-position.y
        && AppState.transition-drag-cursor-y < self.absolute-position.y + self.height;

    private property <bool> transition-drag-over:
        AppState.transition-drag-active && self.transition-cursor-inside;

    changed transition-drag-over => {
        AppState.transition-drag-over-timeline = self.transition-drag-over;
    }

    private property <int> transition-drop-cursor-tick: max(0, round(
        (AppState.transition-drag-cursor-x - lanes.absolute-position.x - TimelineViewState.scroll-x)
        / TimelineStore.zoom / 1px));

    private property <int> transition-drop-row: floor(
        (AppState.transition-drag-cursor-y - lanes.absolute-position.y - TimelineViewState.scroll-y)
        / (root.track-height + root.track-spacing)) - 1;

    private property <TransitionJunctionResolution> transition-drop-res:
        DragBackend.resolve-transition-junction(
            root.sequence,
            root.transition-drop-cursor-tick,
            root.transition-drop-row,
            root.snap-threshold-ticks);

    private property <bool> transition-drag-live: AppState.transition-drag-active;
    changed transition-drag-live => {
        if (!self.transition-drag-live && self.transition-cursor-inside
                && transition-drop-res.valid) {
            EffectsBackend.add-transition(
                transition-drop-res.left-clip-id,
                AppState.transition-drag-id);
        }
    }

    private property <bool> preview-axis-gesture-free:
        !clip-dragging && !clip-trimming && !TimelineViewState.marquee-active
        && !library-drag-over && !transition-drag-over;

    private property <int> hover-preview-watch: TimelineViewState.hover-preview-tick;

    changed hover-preview-watch => {
        if (TimelineViewState.hover-preview-tick >= 0
                && TimelineStore.preview-axis-enabled
                && !TimelineStore.playing
                && preview-axis-gesture-free) {
            EditorStore.on-hover-preview(TimelineViewState.hover-preview-tick);
        }
    }

    // --- library drop targeting --------------------------------------------
    // All lazy: nothing reads these per drag frame; the drop handler below
    // pulls them once when the drag ends.

    // Cursor x in lane-content space → sequence tick (scroll-x is the
    // Flickable viewport-x, ≤ 0 when scrolled right).
    private property <int> library-drop-cursor-tick: max(0, round(
        (AppState.library-drag-cursor-x - lanes.absolute-position.x - TimelineViewState.scroll-x)
        / TimelineStore.zoom / 1px));

    // Lane row under the cursor: row 0 is the ForceHeadSpace spacer, tracks
    // start at row 1 (same pitch — every row is track-height + spacing tall).
    private property <int> library-drop-row: floor(
        (AppState.library-drag-cursor-y - lanes.absolute-position.y - TimelineViewState.scroll-y)
        / (root.track-height + root.track-spacing)) - 1;

    // Where the drop lands (src/snap.rs): the video lane under the cursor
    // (or empty ⇒ the worker creates one at the row), position magneted to
    // clip edges / playhead / tick 0 — or, on the main lane with the magnet
    // on, an insertion between clips (caret preview below).
    private property <LibraryDropResolution> library-drop-res: DragBackend.resolve-library-drop(
        root.sequence,
        AppState.library-drag-lane-kind,
        AppState.library-drag-duration-ticks,
        root.library-drop-cursor-tick,
        root.library-drop-row,
        TimelineStore.playhead-tick,
        root.snap-threshold-ticks,
        TimelineStore.main-magnet-enabled);

    // Commit the drop when the drag ends with the cursor over this panel. The
    // pointer-up fires in the library tile's TouchArea (it owns the grab), so
    // watch the shared drag flag instead of a pointer event.
    private property <bool> library-drag-live: AppState.library-drag-active;
    changed library-drag-live => {
        if (!self.library-drag-live && self.library-cursor-inside) {
            if (AppState.library-drag-generator != "") {
                EditorStore.on-generated-dropped(
                    AppState.library-drag-generator,
                    self.library-drop-res.target-track-id,
                    self.library-drop-res.resolved-start,
                    AppState.library-drag-duration-ticks,
                    self.library-drop-res.target-row);
            } else {
                EditorStore.on-clip-dropped(
                    AppState.library-drag-media-id,
                    self.library-drop-res.target-track-id,
                    self.library-drop-res.resolved-start,
                    self.library-drop-res.target-row,
                    self.library-drop-res.is-insert);
            }
        }
    }

    // --- OS file-drop targeting (Finder / Explorer) ---------------------
    // Mirror the panel + lane-viewport geometry into AppState so the Rust
    // drop handler (src/main.rs) can hit-test the OS drop cursor and convert
    // it to a lane row + tick. winit's file-drop events carry no pointer
    // position, so the handler works from a polled cursor (src/os_drop.rs)
    // rather than a pointer event — the geometry has to be readable outside
    // this component.
    function sync-os-drop-geometry() {
        AppState.timeline-panel-x = self.absolute-position.x;
        AppState.timeline-panel-y = self.absolute-position.y;
        AppState.timeline-panel-w = self.width;
        AppState.timeline-panel-h = self.height;
        AppState.timeline-lanes-x = lanes.absolute-position.x;
        AppState.timeline-lanes-y = lanes.absolute-position.y;
        AppState.timeline-row-pitch = root.row-pitch;
    }
    // A change to any mirrored value flips this sum; the handler re-syncs.
    private property <length> os-drop-geometry-watch:
        self.absolute-position.x + self.absolute-position.y + self.width + self.height
        + lanes.absolute-position.x + lanes.absolute-position.y + root.row-pitch;
    changed os-drop-geometry-watch => {
        self.sync-os-drop-geometry();
    }

    // Landing preview while the OS drag hovers this panel (cursor fed by the
    // Rust polling timer). Same coordinate math as the library drag above.
    private property <bool> os-drop-cursor-inside:
        AppState.os-drop-hover
        && AppState.os-drop-cursor-x >= self.absolute-position.x
        && AppState.os-drop-cursor-x < self.absolute-position.x + self.width
        && AppState.os-drop-cursor-y >= self.absolute-position.y
        && AppState.os-drop-cursor-y < self.absolute-position.y + self.height;

    changed os-drop-cursor-inside => {
        AppState.os-drop-over-timeline = self.os-drop-cursor-inside;
    }

    private property <int> os-drop-cursor-tick: max(0, round(
        (AppState.os-drop-cursor-x - lanes.absolute-position.x - TimelineViewState.scroll-x)
        / TimelineStore.zoom / 1px));

    private property <int> os-drop-row: floor(
        (AppState.os-drop-cursor-y - lanes.absolute-position.y - TimelineViewState.scroll-y)
        / (root.track-height + root.track-spacing)) - 1;

    // Placeholder span for the preview — real durations aren't known until
    // the drop probes the files: 3 seconds at the sequence rate.
    private property <int> os-drop-ghost-ticks:
        max(1, 3 * root.sequence.fps.num / max(1, root.sequence.fps.den));

    // Row + caret resolution through the library-drop resolver so the
    // preview honors the same landing rules the worker applies (empty-main
    // fallback, main-track magnet insertion). Snap threshold 0: the OS drop
    // commit doesn't edge-snap, so the preview must not either.
    private property <LibraryDropResolution> os-drop-res: DragBackend.resolve-library-drop(
        root.sequence,
        AppState.os-drop-lane-kind,
        root.os-drop-ghost-ticks,
        root.os-drop-cursor-tick,
        root.os-drop-row,
        TimelineStore.playhead-tick,
        0,
        TimelineStore.main-magnet-enabled);

    private property <length> track-spacing: AppStore.theme.metrics.spacing.sm;
    private property <length> track-height: TimelineActions.track-lane-height();
    // Lane rows repeat every `row-pitch`; row 0 is the ForceHeadSpace spacer,
    // lane r starts at (r + 1) * row-pitch.
    private property <length> row-pitch: track-height + track-spacing;
    property <Sequence> sequence: EditorStore.project.sequence;

    // CapCut's magnet: ~10px of pull, in ticks at the current zoom; 0 ⇔ off.
    private property <int> snap-threshold-ticks:
        TimelineStore.snap-enabled ? max(1, round(10 / TimelineStore.zoom)) : 0;

    // --- clip drag (move on x and y) -----------------------------------------
    // ClipView records the gesture (press snapshot + cursor deltas); this
    // panel resolves the landing spot — ghost, guides, and the commit all read
    // the same resolution, so the preview is exactly what a release does.

    private property <bool> clip-dragging: TimelineViewState.dragging-clip-id != "";

    private property <int> clip-drag-dx-ticks: round(
        TimelineViewState.drag-dx-px / TimelineStore.zoom / 1px);

    // Lane row under the dragged clip's vertical center (may be out of range:
    // above the first lane or below the last ⇒ new-lane insertion there).
    private property <int> clip-drag-hover-row: floor(
        ((TimelineViewState.dragging-source-row + 1) * row-pitch
            + TimelineViewState.drag-dy-px
            + track-height / 2)
        / row-pitch) - 1;

    private property <ClipDragResolution> clip-drag-res: DragBackend.resolve-clip-drag(
        root.sequence,
        TimelineViewState.dragging-source-track-id,
        TimelineViewState.dragging-clip-id,
        root.clip-drag-dx-ticks,
        root.clip-drag-hover-row,
        TimelineStore.playhead-tick,
        root.snap-threshold-ticks,
        TimelineStore.main-magnet-enabled);

    // Multi-selection drag: one resolution for the whole set (uniform dx +
    // row delta; conflicts with clips outside the set reject the drop —
    // CapCut's policy). Active when the grabbed clip is part of a
    // multi-selection (ClipView raises `drag-is-group`).
    private property <bool> group-dragging:
        clip-dragging && TimelineViewState.drag-is-group;
    private property <bool> single-dragging:
        clip-dragging && !TimelineViewState.drag-is-group;

    private property <GroupDragResolution> group-drag-res: DragBackend.resolve-group-drag(
        root.sequence,
        TimelineStore.selected-ids,
        TimelineViewState.dragging-source-track-id,
        TimelineViewState.dragging-clip-id,
        root.clip-drag-dx-ticks,
        root.clip-drag-hover-row,
        TimelineStore.playhead-tick,
        root.snap-threshold-ticks);

    // ClipView raises `drag-released` on pointer-up; the commit needs the
    // dragging ids, so this panel owns the teardown.
    private property <bool> clip-drag-released: TimelineViewState.drag-released;
    changed clip-drag-released => {
        if (!self.clip-drag-released) {
            return;
        }
        if (TimelineViewState.drag-is-group) {
            if (self.group-drag-res.valid && !self.group-drag-res.is-noop) {
                EditorStore.on-group-moved(self.group-drag-res.moves);
            }
        } else if (self.clip-drag-res.valid && !self.clip-drag-res.is-noop) {
            EditorStore.on-clip-moved(
                TimelineViewState.dragging-clip-id,
                self.clip-drag-res.target-track-id,
                self.clip-drag-res.target-row,
                self.clip-drag-res.resolved-start,
                self.clip-drag-res.is-insert);
        }
        TimelineViewState.dragging-source-track-id = "";
        TimelineViewState.dragging-clip-id = "";
        TimelineViewState.drag-is-group = false;
        TimelineViewState.drag-dx-px = 0;
        TimelineViewState.drag-dy-px = 0;
        TimelineViewState.drag-released = false;
    }

    // --- clip trim (edge drag) -----------------------------------------------
    // The edge handle records the gesture (press snapshot + cursor delta);
    // this panel resolves the new extent — the stretch preview, guide,
    // tooltip, and the commit all read the same resolution.

    private property <bool> clip-trimming: TimelineViewState.trimming-clip-id != "";

    private property <int> clip-trim-dx-ticks: round(
        TimelineViewState.trim-dx-px / TimelineStore.zoom / 1px);

    private property <ClipTrimResolution> clip-trim-res: DragBackend.resolve-clip-trim(
        root.sequence,
        TimelineViewState.trimming-track-id,
        TimelineViewState.trimming-clip-id,
        TimelineViewState.trimming-head,
        root.clip-trim-dx-ticks,
        TimelineStore.playhead-tick,
        root.snap-threshold-ticks,
        TimelineStore.link-enabled,
        TimelineStore.main-magnet-enabled);

    private property <bool> clip-trim-released: TimelineViewState.trim-released;
    changed clip-trim-released => {
        if (!self.clip-trim-released) {
            return;
        }
        if (self.clip-trim-res.valid && !self.clip-trim-res.is-noop) {
            EditorStore.on-clip-trimmed(
                TimelineViewState.trimming-clip-id,
                self.clip-trim-res.new-start,
                self.clip-trim-res.new-duration);
        }
        TimelineViewState.trimming-track-id = "";
        TimelineViewState.trimming-clip-id = "";
        TimelineViewState.trim-dx-px = 0;
        TimelineViewState.trim-released = false;
    }

    // --- marquee selection (drag on empty lane space) ------------------------
    // The wheel-area TouchArea is the press target for everything the clip
    // TouchAreas don't grab, so a press there is by definition on empty
    // space. Armed on press; a drag past the dead zone becomes a live
    // marquee (selection re-resolves per move), a plain click clears the
    // selection (the pre-Phase-10 empty-lane-click behavior).
    private property <bool> marquee-armed: false;

    // --- edge auto-scroll (drags near the viewport edge) --------------------
    // CapCut scrolls the timeline under a drag held near an edge. A ~16ms
    // Timer steps the scroll while the cursor sits in the edge zone; the speed
    // ramps with depth into the zone. Applies to clip moves, trims (x only),
    // and library drops. Clip/trim gestures record px deltas in TouchArea-local
    // space and Slint fires no `moved` while the cursor is still and content
    // scrolls under it, so each step compensates the recorded deltas by the
    // actual scroll applied — keeping the ghost glued to the cursor. Library
    // drops recompute their cursor tick reactively from scroll-x, so they need
    // no compensation.
    private property <bool> gesture-active: clip-dragging || clip-trimming || library-drag-over;
    private property <bool> gesture-vertical: clip-dragging || library-drag-over;

    // Unified window-space cursor for the active gesture.
    private property <length> gesture-px:
        library-drag-over ? AppState.library-drag-cursor-x : TimelineViewState.pointer-window-x;
    private property <length> gesture-py:
        library-drag-over ? AppState.library-drag-cursor-y : TimelineViewState.pointer-window-y;

    private property <length> autoscroll-margin: 32px;
    private property <length> autoscroll-max: 16px; // per tick at the edge

    // Per-tick scroll velocity: + pulls toward tick 0 (cursor near the
    // left/top), − reveals later content (cursor near the right/bottom).
    private property <length> autoscroll-dx:
        !gesture-active ? 0px
        : gesture-px < lanes.absolute-position.x + autoscroll-margin
            ? autoscroll-max * clamp(
                (lanes.absolute-position.x + autoscroll-margin - gesture-px) / autoscroll-margin, 0, 1)
        : gesture-px > lanes.absolute-position.x + lanes.width - autoscroll-margin
            ? -autoscroll-max * clamp(
                (gesture-px - (lanes.absolute-position.x + lanes.width - autoscroll-margin)) / autoscroll-margin, 0, 1)
        : 0px;
    private property <length> autoscroll-dy:
        !gesture-active || !gesture-vertical ? 0px
        : gesture-py < lanes.absolute-position.y + autoscroll-margin
            ? autoscroll-max * clamp(
                (lanes.absolute-position.y + autoscroll-margin - gesture-py) / autoscroll-margin, 0, 1)
        : gesture-py > lanes.absolute-position.y + lanes.height - autoscroll-margin
            ? -autoscroll-max * clamp(
                (gesture-py - (lanes.absolute-position.y + lanes.height - autoscroll-margin)) / autoscroll-margin, 0, 1)
        : 0px;

    autoscroll-timer := Timer {
        interval: 16ms;
        running: gesture-active && (autoscroll-dx != 0px || autoscroll-dy != 0px);
        triggered => {
            // Clamp to the scroll bounds and measure what actually moved, so
            // the delta compensation matches the real scroll (no drift at the
            // far edges).
            root.autoscroll-applied-x =
                clamp(TimelineViewState.scroll-x + root.autoscroll-dx, root.min-scroll-x, 0px)
                    - TimelineViewState.scroll-x;
            root.autoscroll-applied-y =
                clamp(TimelineViewState.scroll-y + root.autoscroll-dy, root.min-scroll-y, 0px)
                    - TimelineViewState.scroll-y;
            TimelineViewState.scroll-x += root.autoscroll-applied-x;
            TimelineViewState.scroll-y += root.autoscroll-applied-y;
            if (clip-dragging) {
                TimelineViewState.drag-dx-px -= root.autoscroll-applied-x;
                TimelineViewState.drag-dy-px -= root.autoscroll-applied-y;
            }
            if (clip-trimming) {
                TimelineViewState.trim-dx-px -= root.autoscroll-applied-x;
            }
        }
    }

    private property <length> autoscroll-applied-x;
    private property <length> autoscroll-applied-y;

    // Available height for the scrolling rows (everything below toolbar+ruler).
    // Both flickables below share this — it's the row's own `height`.
    private property <length> row-height: root.height - tb.height - rl.height;

    // Total intrinsic height of the track content. The `+1` mirrors the
    // `ForceHeadSpace` row at the top of both flickables so heads and lanes
    // stay vertically aligned.
    private property <length> content-height: TimelineLib.calc-viewport-height(
        sequence.tracks.length + 1,
        track-height,
        track-spacing,
    );
    private property <length> content-width: TimelineLib.calc-viewport-width(
        sequence,
        TimelineStore.zoom,
    );

    // The Flickable's clamp range is `[row-height - content-height, 0]` (or
    // `[0, 0]` when content fits). Flickable re-clamps `viewport-y` on user
    // interaction but NOT on container resize. Without the `changed` hook
    // below, dragging the splitter taller while scrolled to the bottom
    // leaves a stale `scroll-y` past the new lower bound, which renders as
    // empty space below the last track until the next scroll event snaps
    // it back. Watching the bound (not just `row-height`) also covers
    // future track-count / track-height / spacing changes.
    private property <length> min-scroll-y: min(0px, row-height - content-height);

    changed min-scroll-y => {
        TimelineViewState.scroll-y = clamp(TimelineViewState.scroll-y, min-scroll-y, 0px);
    }

    // Same stale-scroll hazard on the x axis, now reachable through the
    // toolbar zoom slider: zooming out shrinks `content-width`, and a
    // viewport scrolled far right would keep a `scroll-x` past the new
    // bound (blank timeline until the next user scroll snaps it back).
    private property <length> min-scroll-x: min(0px, lanes.width - content-width);

    changed min-scroll-x => {
        TimelineViewState.scroll-x = clamp(TimelineViewState.scroll-x, min-scroll-x, 0px);
    }

    // Playback page-follow: leave the viewport still while the playhead is
    // visible, then reveal it with context in the direction of travel. Forward
    // playback lands near the left edge; reverse playback mirrors that near the
    // right. Ruler hand-scrubbing has its own smooth edge-scroll loop and
    // temporarily suspends this page behavior.
    private property <length> playback-playhead-content-x:
        TimelineStore.playhead-tick * TimelineStore.zoom * 1px;
    private property <length> playback-playhead-viewport-x:
        playback-playhead-content-x + TimelineViewState.scroll-x;
    private property <bool> playback-follow-active:
        TimelineStore.playing && !TimelineViewState.playhead-scrubbing;

    function reveal-playing-playhead() {
        if (!playback-follow-active || lanes.width <= 0px) {
            return;
        }
        if (playback-playhead-viewport-x < 0px
                || playback-playhead-viewport-x >= lanes.width) {
            TimelineViewState.scroll-x = clamp(
                (TimelineStore.play-speed-num < 0 ? lanes.width * 0.9 : lanes.width * 0.1)
                    - playback-playhead-content-x,
                min-scroll-x,
                0px);
        }
    }

    // A tick change covers ordinary playback, shuttle, live seeks, and loop
    // wraps. The playing edge separately reveals an already-off-screen
    // playhead before the first clock tick after Play/J/L.
    private property <int> playback-follow-tick: TimelineStore.playhead-tick;
    changed playback-follow-tick => {
        root.reveal-playing-playhead();
    }
    private property <bool> playback-follow-active-watch: playback-follow-active;
    changed playback-follow-active-watch => {
        if (self.playback-follow-active-watch) {
            root.reveal-playing-playhead();
        }
    }

    // Mirror the lane viewport width so zoom anchoring (TimelineActions
    // .set-zoom) can keep the playhead / view center stationary.
    private property <length> lanes-width: lanes.width;

    changed lanes-width => {
        TimelineViewState.viewport-w = self.lanes-width;
    }

    // Pinch-zoom base scale captured at gesture start.
    private property <float> timeline-pinch-base-zoom: TimelineStore.zoom;

    // Horizontal scrollbar: visible when content is wider than the viewport.
    // Thumb geometry and drag math live in the shared `CutlassScrollBar`
    // (see the instance at the bottom of `lane-host`); the timeline only
    // owns the reveal/fade logic below.
    private property <bool> h-scroll-needed: content-width > lanes-width + 1px;

    // Fade the scrollbar in while scrolling, out after idle.
    private property <int> scrollbar-activity: TimelineViewState.scrollbar-activity-nonce;
    private property <float> h-scrollbar-opacity: 0.0;

    changed scrollbar-activity => {
        h-scrollbar-opacity = 0.85;
        scrollbar-fade.restart();
    }

    // Reveal on any horizontal scroll, whatever drove it (wheel, thumb
    // drag, zoom clamp, programmatic) — the explicit nonce bumps in the
    // wheel/zoom handlers predate this and remain harmless.
    private property <length> h-scroll-pos: TimelineViewState.scroll-x;

    changed h-scroll-pos => {
        TimelineViewState.scrollbar-activity-nonce += 1;
    }

    scrollbar-fade := Timer {
        interval: 1500ms;
        running: false;
        triggered => {
            h-scrollbar-opacity = 0.25;
        }
    }

    init => {
        TimelineViewState.viewport-w = lanes.width;
        self.sync-os-drop-geometry();
    }

    // The playhead → preview-frame-request watcher lives at window scope
    // (app.slint), not here: this panel unmounts in fullscreen preview
    // mode and playback must keep rendering there.

    VerticalLayout {

        spacing: AppStore.theme.metrics.spacing.none;

        tb := Toolbar {
            height: AppStore.theme.metrics.layout.toolbar-height;
        }

        rl := HorizontalLayout {
            height: 30px;
            spacing: 60px;

            Rectangle { //head space
                width: 100px;
            }

            Rectangle { // ruler container — clip so marks that scroll into the head column are hidden.
                clip: true;
                Ruler { }
            }
        }

        // A `Flickable`'s preferred-height equals its `viewport-height`
        // (see Slint docs). That propagates up through `HorizontalLayout`
        // and makes this row claim the full panel height instead of just
        // the remainder after toolbar+ruler — overflowing the panel and
        // leaving no scroll range. Pin the row to the leftover space.
        HorizontalLayout {

            height: row-height;
            spacing: 60px;
            Rectangle {
                height: 100%;
                width: 100px;

                Flickable {
                    viewport-y <=> TimelineViewState.scroll-y;

                    viewport-height: max(self.height, content-height);

                    VerticalLayout {
                        vertical-stretch: 1;
                        horizontal-stretch: 1;
                        spacing: track-spacing;

                        ForceHeadSpace { }

                        for t[lane-idx] in sequence.tracks: TrackHead {
                            track: t;
                            track-row: lane-idx;
                            lane-height: root.track-height;
                        }
                    }
                }

                VerticalDivider {
                    x: parent.width - self.width;
                    width: AppStore.theme.metrics.stroke.thin;
                }
            }

            // Wraps the lanes so wheel/trackpad scroll has somewhere to land:
            // the lane Flickable is `interactive: false` (it would fight clip
            // drags), and scroll events bubble out of the clip TouchAreas to
            // this ancestor. Plain wheel scrolls the lanes; Ctrl/Cmd+wheel
            // zooms anchored on the cursor tick. Pointer grabs still go to the
            // innermost clip/lane TouchArea, so dragging is unaffected.
            lane-host := Rectangle {
                horizontal-stretch: 1;
                clip: true;

    private property <bool> wheel-hover: wheel-area.has-hover;

    changed wheel-hover => {
        if (!wheel-hover) {
            TimelineViewState.hover-preview-tick = -1;
            EditorStore.on-hover-preview-ended();
        }
    }

            wheel-area := TouchArea {
                width: 100%;
                height: 100%;

                changed pressed => {
                    if (self.pressed) {
                        AppState.refocus-shortcuts();
                        root.marquee-armed = true;
                        TimelineViewState.marquee-anchor-x = self.mouse-x - TimelineViewState.scroll-x;
                        TimelineViewState.marquee-anchor-y = self.mouse-y - TimelineViewState.scroll-y;
                        TimelineViewState.marquee-x = TimelineViewState.marquee-anchor-x;
                        TimelineViewState.marquee-y = TimelineViewState.marquee-anchor-y;
                    } else {
                        if (!TimelineViewState.marquee-active && root.marquee-armed) {
                            // Click without drag: clear the selection.
                            TimelineActions.clear-selection();
                        }
                        root.marquee-armed = false;
                        TimelineViewState.marquee-active = false;
                        TimelineViewState.hover-preview-tick = -1;
                        EditorStore.on-hover-preview-ended();
                    }
                }

                moved => {
                    if (TimelineStore.preview-axis-enabled && !TimelineStore.playing
                            && root.preview-axis-gesture-free) {
                        TimelineViewState.hover-preview-tick = max(0, round(
                            (self.mouse-x - TimelineViewState.scroll-x)
                            / TimelineStore.zoom / 1px));
                    }
                    if (!root.marquee-armed) {
                        return;
                    }
                    TimelineViewState.marquee-x = self.mouse-x - TimelineViewState.scroll-x;
                    TimelineViewState.marquee-y = self.mouse-y - TimelineViewState.scroll-y;
                    if (!TimelineViewState.marquee-active
                            && (abs((TimelineViewState.marquee-x - TimelineViewState.marquee-anchor-x) / 1px) > 3
                                || abs((TimelineViewState.marquee-y - TimelineViewState.marquee-anchor-y) / 1px) > 3)) {
                        TimelineViewState.marquee-active = true;
                    }
                    if (TimelineViewState.marquee-active) {
                        // Live selection, CapCut-style: re-resolve the set on
                        // every move. Rows are lane units (row r = lane r).
                        TimelineStore.apply-selection(SelectionBackend.resolve-marquee(
                            root.sequence,
                            round(min(TimelineViewState.marquee-anchor-x, TimelineViewState.marquee-x)
                                / TimelineStore.zoom / 1px),
                            round(max(TimelineViewState.marquee-anchor-x, TimelineViewState.marquee-x)
                                / TimelineStore.zoom / 1px),
                            min(TimelineViewState.marquee-anchor-y, TimelineViewState.marquee-y)
                                / root.row-pitch - 1,
                            max(TimelineViewState.marquee-anchor-y, TimelineViewState.marquee-y)
                                / root.row-pitch - 1,
                            TimelineStore.link-enabled));
                    }
                }

                scroll-event(e) => {
                    if (e.modifiers.control || e.modifiers.meta) {
                        // Cursor-anchored zoom in log/slider space.
                        TimelineActions.set-zoom-anchored(
                            TimelineActions.slider-to-zoom(clamp(
                                TimelineActions.zoom-to-slider(TimelineStore.zoom)
                                    + e.delta-y / 1px * 0.15,
                                0, 100)),
                            (self.mouse-x - TimelineViewState.scroll-x) / 1px / TimelineStore.zoom);
                        TimelineViewState.scrollbar-activity-nonce += 1;
                        return accept;
                    }
                    // Shift (or a horizontal trackpad swipe) scrolls the
                    // timeline sideways; otherwise the wheel scrolls lanes.
                    if (e.modifiers.shift) {
                        TimelineViewState.scroll-x = clamp(
                            TimelineViewState.scroll-x + e.delta-y, root.min-scroll-x, 0px);
                    } else if (abs(e.delta-x / 1px) > abs(e.delta-y / 1px)) {
                        TimelineViewState.scroll-x = clamp(
                            TimelineViewState.scroll-x + e.delta-x, root.min-scroll-x, 0px);
                    } else {
                        TimelineViewState.scroll-y = clamp(
                            TimelineViewState.scroll-y + e.delta-y, root.min-scroll-y, 0px);
                    }
                    TimelineViewState.scrollbar-activity-nonce += 1;
                    return accept;
                }

                lanes := Flickable {
                    width: 100%;
                    height: 100%;
                    interactive: false;
                    viewport-width: max(content-width, self.width);
                    viewport-height: max(self.height, content-height);

                    viewport-y <=> TimelineViewState.scroll-y;
                    viewport-x <=> TimelineViewState.scroll-x;

                    // Lane backdrops are absolutely positioned in content
                    // space — deliberately NOT a layout. Width bindings on
                    // layout children go stale when zoom grows content-width
                    // without a scroll event: the layout solver owns child
                    // geometry and its cached pass survives the binding change
                    // (a5f43dd bound the enclosing VerticalLayout, then the
                    // per-lane width — pinch out→in still glitched). The
                    // overlay bands below use plain x/y/width bindings and
                    // never go stale, so the lanes now use the same idiom;
                    // the y math mirrors the head column's spacer + spacing.
                    for t[lane-idx] in sequence.tracks: TrackLane {
                        x: 0;
                        y: (lane-idx + 1) * row-pitch;
                        width: max(content-width, lanes.width);
                        height: track-height;
                        track-id: t.id;
                        kind: t.kind;
                        for c in t.clips: ClipView {
                            model: c;
                            track-id: t.id;
                            track-row: lane-idx;
                            track-kind: t.kind;
                            track-color: t.color;
                            track-enabled: t.enabled;
                            track-locked: t.locked;
                            height: parent.height - 5px;
                            zoom: TimelineStore.zoom;
                        }
                    }

                LaneOverlays {
                    sequence: root.sequence;
                    row-pitch: root.row-pitch;
                    track-height: root.track-height;
                    track-spacing: root.track-spacing;
                    content-width: root.content-width;
                    content-height: root.content-height;
                    single-dragging: root.single-dragging;
                    group-dragging: root.group-dragging;
                    clip-trimming: root.clip-trimming;
                    library-drag-over: root.library-drag-over;
                    os-drop-cursor-inside: root.os-drop-cursor-inside;
                    transition-drag-over: root.transition-drag-over;
                    preview-axis-gesture-free: root.preview-axis-gesture-free;
                    os-drop-ghost-ticks: root.os-drop-ghost-ticks;
                    clip-drag-res: root.clip-drag-res;
                    library-drop-res: root.library-drop-res;
                    os-drop-res: root.os-drop-res;
                    group-drag-res: root.group-drag-res;
                    clip-trim-res: root.clip-trim-res;
                    transition-drop-res: root.transition-drop-res;
                }

                }
            }

            // Trackpad pinch-to-zoom on the timeline (CapCut desktop). `scale`
            // is cumulative since the pinch started, anchored on the pinch
            // center; non-gesture events fall through to the TouchArea below.
            ScaleRotateGestureHandler {
                width: 100%;
                height: 100%;
                started => {
                    root.timeline-pinch-base-zoom = TimelineStore.zoom;
                }
                updated => {
                    TimelineActions.set-zoom-anchored(
                        clamp(
                            root.timeline-pinch-base-zoom * self.scale,
                            TimelineActions.min-zoom,
                            TimelineActions.max-zoom),
                        (self.center.x - TimelineViewState.scroll-x) / 1px / TimelineStore.zoom);
                    TimelineViewState.scrollbar-activity-nonce += 1;
                }
            }

            // Slim horizontal scrollbar overlay (auto-fades when idle).
            // Shared thumb geometry / drag / track-click math from
            // `CutlassScrollBar`; the timeline drives reveal via
            // `scrollbar-activity-nonce` and keeps the bar awake while
            // the pointer is on it. Fully hidden (opacity 0) the bar is
            // click-through; wheel events over it fall through to
            // `wheel-area` like everywhere else on the lanes.
            if root.h-scroll-needed: CutlassScrollBar {
                horizontal: true;
                x: 0;
                y: parent.height - AppStore.theme.scrollbar.size;
                width: parent.width;
                height: AppStore.theme.scrollbar.size;
                opacity: (self.dragging || self.hovered) ? 0.85 : root.h-scrollbar-opacity;
                bar-interactive: root.h-scrollbar-opacity > 0.001 || self.dragging || self.hovered;

                visible-extent: lanes.width;
                content-extent: root.content-width;
                offset <=> TimelineViewState.scroll-x;
            }
            }
        }
    }
}
