// App settings screen. Opened from the native "Cutlass" menu → Settings… on
// macOS and the title-bar gear everywhere. In-window modal like the canvas/
// export dialogs, with a CapCut-style left rail of sections and a content
// pane.
//
// All editable state lives in SettingsBackend (and the theme in
// AppStore.theme-id, so it switches live). Fields two-way bind to those
// globals; dismissal succeeds only when SettingsBackend.save returns true
// (wired in src/main.rs). Theme changes preview instantly.

import {
    CutlassLineInput,
    CutlassText,
    AccentButton,
    SubtleButton,
    CutlassDropdown,
    CutlassScrollView,
    CutlassColorPicker,
} from "../components/index.slint";
import { AppStore } from "../store/index.slint";
import { AiModelRow, CacheUsageRow, SettingsBackend } from "../lib/settings-backend.slint";
import { AppState } from "../state.slint";

// One row in the left rail.
component NavItem inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    callback clicked();

    height: 32px;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: selected
        ? AppStore.theme.accent.primary.with-alpha(0.14)
        : (ta.has-hover ? #ffffff10 : transparent);

    CutlassText {
        x: AppStore.theme.metrics.spacing.md;
        width: parent.width - 2 * AppStore.theme.metrics.spacing.md;
        height: parent.height;
        vertical-alignment: center;
        text: root.label;
        style: AppStore.theme.typography.label;
        foreground: root.selected ? AppStore.theme.accent.primary : AppStore.theme.text.secondary;
        overflow: elide;
    }

    ta := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

// A section heading inside a pane.
component PaneTitle inherits CutlassText {
    style: AppStore.theme.typography.heading-sm;
}

// Muted explanatory line under a heading or field.
component Hint inherits CutlassText {
    wrap: word-wrap;
    style: AppStore.theme.typography.caption;
    foreground: AppStore.theme.text.muted;
}

// Label + control row: a fixed-width label gutter, then the control stretches.
component FieldRow inherits HorizontalLayout {
    in property <string> label;
    spacing: AppStore.theme.metrics.spacing.md;

    CutlassText {
        width: 112px;
        vertical-alignment: center;
        text: root.label;
        style: AppStore.theme.typography.label;
        foreground: AppStore.theme.text.secondary;
    }
    @children
}

// Pill chip for two-way mode picks (API protocol, reasoning summary).
component ModeChip inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked();

    width: lbl.preferred-width + 16px;
    height: 24px;
    border-radius: 12px;
    background: root.active ? AppStore.theme.accent.primary.with-alpha(0.22)
        : ta.has-hover ? #ffffff0a
        : transparent;
    border-width: 1px;
    border-color: root.active ? AppStore.theme.accent.primary : #ffffff14;

    lbl := CutlassText {
        text: root.label;
        style: { size: 11px, weight: 600, italic: false };
        foreground: root.active ? AppStore.theme.accent.primary : AppStore.theme.text.secondary;
    }

    ta := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

// Curated model row for Local / OpenRouter pickers.
component ModelPickRow inherits Rectangle {
    in property <AiModelRow> entry;
    // Driven by SettingsBackend.ai-model so clicks update instantly.
    in property <bool> selected;
    callback clicked();

    height: 32px;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: root.selected ? AppStore.theme.accent.primary.with-alpha(0.18)
        : ta.has-hover && root.entry.available ? #ffffff0a
        : transparent;
    border-width: 1px;
    border-color: root.selected ? AppStore.theme.accent.primary : transparent;
    opacity: root.entry.available ? 1.0 : 0.45;

    HorizontalLayout {
        padding-left: AppStore.theme.metrics.spacing.sm;
        padding-right: AppStore.theme.metrics.spacing.sm;
        spacing: AppStore.theme.metrics.spacing.sm;
        alignment: center;

        CutlassText {
            horizontal-stretch: 1;
            text: root.entry.display;
            style: AppStore.theme.typography.label;
            foreground: root.selected
                ? AppStore.theme.accent.primary
                : AppStore.theme.text.primary;
        }
        if root.entry.vendor != "": CutlassText {
            text: root.entry.vendor;
            style: AppStore.theme.typography.caption;
            foreground: AppStore.theme.text.secondary;
        }
    }

    ta := TouchArea {
        enabled: root.entry.available;
        clicked => {
            root.clicked();
        }
    }
}

// One registry-owned cache. Operations always use the stable cache id; the
// path is display-only so moving data cannot bypass Rust's relocation path.
component CacheUsageCard inherits Rectangle {
    in property <CacheUsageRow> cache;
    private property <bool> row-busy: SettingsBackend.cache-busy-id == root.cache.id;
    private property <bool> controls-disabled: SettingsBackend.cache-loading
        || SettingsBackend.cache-busy-id != "";

    height: 66px;
    clip: true;
    border-radius: AppStore.theme.metrics.radius.md;
    border-width: 1px;
    border-color: root.row-busy
        ? AppStore.theme.accent.primary.with-alpha(0.44)
        : AppStore.theme.surface.divider;
    background: root.row-busy
        ? AppStore.theme.accent.primary.with-alpha(0.07)
        : AppStore.theme.surface.content-background;

    VerticalLayout {
        padding: AppStore.theme.metrics.spacing.sm;
        spacing: AppStore.theme.metrics.spacing.xs;

        HorizontalLayout {
            height: 20px;
            spacing: AppStore.theme.metrics.spacing.sm;

            CutlassText {
                horizontal-stretch: 1;
                text: root.cache.label;
                style: AppStore.theme.typography.label;
                overflow: elide;
            }

            CutlassText {
                text: (root.row-busy ? "Working… · " : "")
                    + (root.cache.kind == "disk" ? "Disk" : "Memory")
                    + " · " + root.cache.size-label
                    + " · " + root.cache.item-count-label;
                style: AppStore.theme.typography.caption;
                foreground: root.row-busy
                    ? AppStore.theme.accent.primary
                    : AppStore.theme.text.secondary;
                overflow: elide;
            }
        }

        HorizontalLayout {
            height: 26px;
            spacing: AppStore.theme.metrics.spacing.sm;

            CutlassText {
                horizontal-stretch: 1;
                text: root.cache.path == "" ? "In memory" : root.cache.path;
                mono: root.cache.path != "";
                style: AppStore.theme.typography.caption;
                foreground: AppStore.theme.text.muted;
                overflow: elide;
                vertical-alignment: center;
            }

            if root.cache.clearable: SubtleButton {
                label: "Clear";
                enabled: !root.controls-disabled;
                clicked => {
                    SettingsBackend.clear-cache(root.cache.id);
                }
            }

            if root.cache.kind == "disk": SubtleButton {
                label: "Reveal";
                enabled: !root.controls-disabled;
                clicked => {
                    SettingsBackend.reveal-cache(root.cache.id);
                }
            }

            if root.cache.kind == "disk": SubtleButton {
                label: "Move";
                enabled: SettingsBackend.cache-relocation-enabled
                    && root.cache.relocatable
                    && !root.controls-disabled;
                clicked => {
                    SettingsBackend.relocate-cache(root.cache.id);
                }
            }
        }
    }
}

// Demo host for the panel-only color picker (Settings → Appearance).
component ColorPickerDemo inherits Rectangle {
    private property <color> draft: #3bb0ffff;
    private property <[color]> recent: [#ff3b3bff, #3bff6eff, #3b6eff80];

    border-radius: AppStore.theme.metrics.radius.md;
    background: AppStore.theme.panel.background;
    border-width: 1px;
    border-color: #ffffff1f;

    VerticalLayout {
        padding: AppStore.theme.metrics.spacing.md;

        CutlassColorPicker {
            current <=> root.draft;
            recent-colors: root.recent;
            preview(_) => { }
            committed(c) => {
                root.draft = c;
            }
        }
    }
}

export component SettingsDialog inherits Rectangle {
    background: #000000A0;

    // 0 = AI, 1 = Appearance, 2 = Storage, 3 = Account.
    in-out property <int> section: 0;

    property <[string]> theme-names: ["Graphite (default)", "Ember", "Dark blue"];

    init => {
        SettingsBackend.refresh-caches();
    }

    changed section => {
        settings-scroll.viewport-y = 0px;
    }

    function close() {
        if (SettingsBackend.cache-busy-id != "") {
            root.section = 2;
            SettingsBackend.cache-status = "";
            SettingsBackend.cache-error = "Wait for the cache operation to finish before closing Settings.";
            return;
        }
        if (SettingsBackend.save()) {
            AppState.settings-open = false;
        }
    }

    // Scrim: absorb every pointer event so the editor underneath is inert.
    TouchArea { }

    panel := Rectangle {
        width: 760px;
        height: 540px;
        background: AppStore.theme.panel.background;
        border-radius: AppStore.theme.metrics.radius.lg;
        border-width: 1px;
        border-color: #ffffff14;
        drop-shadow-blur: 32px;
        drop-shadow-color: #00000080;
        drop-shadow-offset-y: 8px;

        // Keep clicks inside the panel from reaching the scrim above.
        TouchArea { }

        VerticalLayout {
            padding: AppStore.theme.metrics.spacing.xl;
            spacing: AppStore.theme.metrics.spacing.lg;

            // --- header ----------------------------------------------------
            HorizontalLayout {
                CutlassText {
                    text: "Settings";
                    style: AppStore.theme.typography.heading-md;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                close-button := Rectangle {
                    width: 26px;
                    height: 26px;
                    border-radius: AppStore.theme.metrics.radius.sm;
                    background: close-ta.has-hover ? #ffffff14 : transparent;

                    Image {
                        width: 14px;
                        height: 14px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("../../../../assets/icon/ui/x.svg");
                        image-fit: contain;
                        colorize: AppStore.theme.text.secondary;
                    }

                    close-ta := TouchArea {
                        clicked => {
                            root.close();
                        }
                    }
                }
            }

            // --- rail + content -------------------------------------------
            HorizontalLayout {
                vertical-stretch: 1;
                spacing: AppStore.theme.metrics.spacing.lg;

                // Left rail.
                VerticalLayout {
                    width: 168px;
                    spacing: AppStore.theme.metrics.spacing.xs;

                    NavItem {
                        label: "AI provider";
                        selected: root.section == 0;
                        clicked => {
                            root.section = 0;
                        }
                    }
                    NavItem {
                        label: "Appearance";
                        selected: root.section == 1;
                        clicked => {
                            root.section = 1;
                        }
                    }
                    NavItem {
                        label: "Storage & cache";
                        selected: root.section == 2;
                        clicked => {
                            root.section = 2;
                            SettingsBackend.refresh-caches();
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                    }
                }

                // Vertical hairline between rail and content.
                Rectangle {
                    width: 1px;
                    background: #ffffff12;
                }

                // Content pane.
                settings-scroll := CutlassScrollView {
                    horizontal-stretch: 1;
                    viewport-width: self.width;
                    viewport-height: content.preferred-height;
                    show-horizontal-scrollbar: false;
                    enable-key-scroll: true;

                    content := VerticalLayout {
                        width: max(0px, settings-scroll.width - AppStore.theme.scrollbar.size);
                        padding-right: AppStore.theme.metrics.spacing.sm;
                        alignment: start;
                        spacing: AppStore.theme.metrics.spacing.md;

                        // --- AI provider ----------------------------------
                        if root.section == 0: VerticalLayout {
                            spacing: AppStore.theme.metrics.spacing.md;

                            PaneTitle {
                                text: "AI provider";
                            }
                            Hint {
                                text: "Local models on your machine, OpenRouter for cloud, or Advanced for any OpenAI-compatible endpoint. Changes apply on your next prompt — no restart.";
                            }

                            HorizontalLayout {
                                spacing: AppStore.theme.metrics.spacing.sm;
                                alignment: start;

                                ModeChip {
                                    label: "Local";
                                    active: SettingsBackend.ai-source == "local";
                                    clicked => {
                                        SettingsBackend.ai-source = "local";
                                        SettingsBackend.refresh-local-models();
                                    }
                                }
                                ModeChip {
                                    label: "OpenRouter";
                                    active: SettingsBackend.ai-source == "openrouter";
                                    clicked => {
                                        SettingsBackend.ai-source = "openrouter";
                                        SettingsBackend.refresh-local-models();
                                    }
                                }
                                ModeChip {
                                    label: "Advanced";
                                    active: SettingsBackend.ai-source == "custom";
                                    clicked => {
                                        SettingsBackend.ai-source = "custom";
                                        SettingsBackend.refresh-local-models();
                                    }
                                }
                            }

                            // --- Local ------------------------------------
                            if SettingsBackend.ai-source == "local": VerticalLayout {
                                spacing: AppStore.theme.metrics.spacing.md;

                                Hint {
                                    text: "Point at Ollama, LM Studio, or any local OpenAI-compatible server. Only models Cutlass supports are listed.";
                                }
                                FieldRow {
                                    label: "Endpoint";
                                    CutlassLineInput {
                                        text <=> SettingsBackend.ai-base-url;
                                        placeholder-text: "http://localhost:11434/v1";
                                        accessibility-label: "Local AI endpoint";
                                        mono: true;
                                    }
                                }
                                FieldRow {
                                    label: "Model";
                                    VerticalLayout {
                                        spacing: 4px;
                                        for row in SettingsBackend.ai-model-rows: ModelPickRow {
                                            entry: row;
                                            selected: SettingsBackend.ai-model == row.id;
                                            clicked => {
                                                SettingsBackend.ai-model = row.id;
                                            }
                                        }
                                    }
                                }
                                HorizontalLayout {
                                    spacing: AppStore.theme.metrics.spacing.md;
                                    alignment: start;

                                    SubtleButton {
                                        label: SettingsBackend.ai-testing ? "Refreshing…" : "Refresh models";
                                        enabled: !SettingsBackend.ai-testing
                                            && SettingsBackend.ai-base-url != "";
                                        clicked => {
                                            SettingsBackend.refresh-local-models();
                                        }
                                    }
                                    SubtleButton {
                                        label: SettingsBackend.ai-testing ? "Testing…" : "Test connection";
                                        enabled: !SettingsBackend.ai-testing
                                            && SettingsBackend.ai-base-url != ""
                                            && SettingsBackend.ai-model != "";
                                        clicked => {
                                            SettingsBackend.test-connection();
                                        }
                                    }
                                    CutlassText {
                                        vertical-alignment: center;
                                        text: SettingsBackend.ai-test-status;
                                        wrap: word-wrap;
                                        style: AppStore.theme.typography.caption;
                                        foreground: SettingsBackend.ai-test-ok
                                            ? AppStore.theme.accent.primary
                                            : #FF6B6B;
                                    }
                                }
                            }

                            // --- OpenRouter -------------------------------
                            if SettingsBackend.ai-source == "openrouter": VerticalLayout {
                                spacing: AppStore.theme.metrics.spacing.md;

                                Hint {
                                    text: "One OpenRouter key unlocks the curated cloud models below. Got provider keys? Attach them in OpenRouter's BYOK settings — Cutlass only needs your OR key.";
                                }
                                FieldRow {
                                    label: "API key";
                                    CutlassLineInput {
                                        text <=> SettingsBackend.ai-api-key;
                                        placeholder-text: "sk-or-…";
                                        accessibility-label: "OpenRouter API key";
                                        input-type: InputType.password;
                                        mono: true;
                                    }
                                }
                                FieldRow {
                                    label: "Key from env";
                                    CutlassLineInput {
                                        text <=> SettingsBackend.ai-api-key-env;
                                        placeholder-text: "e.g. OPENROUTER_API_KEY (overrides the key above)";
                                        accessibility-label: "OpenRouter API key environment variable";
                                        mono: true;
                                    }
                                }
                                FieldRow {
                                    label: "Model";
                                    VerticalLayout {
                                        spacing: 4px;
                                        for row in SettingsBackend.ai-model-rows: ModelPickRow {
                                            entry: row;
                                            selected: SettingsBackend.ai-model == row.id;
                                            clicked => {
                                                SettingsBackend.ai-model = row.id;
                                            }
                                        }
                                    }
                                }
                                HorizontalLayout {
                                    spacing: AppStore.theme.metrics.spacing.md;
                                    alignment: start;

                                    SubtleButton {
                                        label: SettingsBackend.ai-testing ? "Testing…" : "Test connection";
                                        enabled: !SettingsBackend.ai-testing
                                            && SettingsBackend.ai-model != ""
                                            && (SettingsBackend.ai-api-key != ""
                                                || SettingsBackend.ai-api-key-env != "");
                                        clicked => {
                                            SettingsBackend.test-connection();
                                        }
                                    }
                                    CutlassText {
                                        vertical-alignment: center;
                                        text: SettingsBackend.ai-test-status;
                                        wrap: word-wrap;
                                        style: AppStore.theme.typography.caption;
                                        foreground: SettingsBackend.ai-test-ok
                                            ? AppStore.theme.accent.primary
                                            : #FF6B6B;
                                    }
                                }
                            }

                            // --- Advanced (freeform) ----------------------
                            if SettingsBackend.ai-source == "custom": VerticalLayout {
                                spacing: AppStore.theme.metrics.spacing.md;

                                Hint {
                                    text: "Escape hatch for outages, unlisted providers, or self-hosted gateways. OpenAI-compatible Chat Completions or Responses.";
                                }
                                FieldRow {
                                    label: "Endpoint";
                                    CutlassLineInput {
                                        text <=> SettingsBackend.ai-base-url;
                                        placeholder-text: "http://localhost:11434/v1";
                                        accessibility-label: "AI endpoint";
                                        mono: true;
                                    }
                                }
                                FieldRow {
                                    label: "Model";
                                    CutlassLineInput {
                                        text <=> SettingsBackend.ai-model;
                                        placeholder-text: "qwen3:14b";
                                        accessibility-label: "AI model";
                                        mono: true;
                                    }
                                }
                                FieldRow {
                                    label: "API protocol";
                                    HorizontalLayout {
                                        spacing: AppStore.theme.metrics.spacing.sm;
                                        alignment: start;

                                        ModeChip {
                                            label: "Chat Completions";
                                            active: SettingsBackend.ai-api-protocol == "chat_completions";
                                            clicked => {
                                                SettingsBackend.ai-api-protocol = "chat_completions";
                                            }
                                        }
                                        ModeChip {
                                            label: "Responses";
                                            active: SettingsBackend.ai-api-protocol == "responses";
                                            clicked => {
                                                SettingsBackend.ai-api-protocol = "responses";
                                            }
                                        }
                                    }
                                }
                                if SettingsBackend.ai-api-protocol == "responses": FieldRow {
                                    label: "Reasoning";
                                    HorizontalLayout {
                                        spacing: AppStore.theme.metrics.spacing.sm;
                                        alignment: start;

                                        ModeChip {
                                            label: "Show summaries";
                                            active: SettingsBackend.ai-reasoning-summary == "auto";
                                            clicked => {
                                                SettingsBackend.ai-reasoning-summary = "auto";
                                            }
                                        }
                                        ModeChip {
                                            label: "Off";
                                            active: SettingsBackend.ai-reasoning-summary == "off";
                                            clicked => {
                                                SettingsBackend.ai-reasoning-summary = "off";
                                            }
                                        }
                                    }
                                }
                                if SettingsBackend.ai-api-protocol == "responses": Hint {
                                    text: "Responses supports reasoning models with tools. Summaries are provider-generated, not raw chain-of-thought.";
                                }
                                FieldRow {
                                    label: "API key";
                                    CutlassLineInput {
                                        text <=> SettingsBackend.ai-api-key;
                                        placeholder-text: "Optional — local servers need none";
                                        accessibility-label: "AI API key";
                                        input-type: InputType.password;
                                        mono: true;
                                    }
                                }
                                FieldRow {
                                    label: "Key from env";
                                    CutlassLineInput {
                                        text <=> SettingsBackend.ai-api-key-env;
                                        placeholder-text: "e.g. OPENAI_API_KEY (overrides the key above)";
                                        accessibility-label: "AI API key environment variable";
                                        mono: true;
                                    }
                                }

                                HorizontalLayout {
                                    spacing: AppStore.theme.metrics.spacing.md;
                                    alignment: start;

                                    SubtleButton {
                                        label: SettingsBackend.ai-testing ? "Testing…" : "Test connection";
                                        enabled: !SettingsBackend.ai-testing
                                            && SettingsBackend.ai-base-url != ""
                                            && SettingsBackend.ai-model != "";
                                        clicked => {
                                            SettingsBackend.test-connection();
                                        }
                                    }

                                    CutlassText {
                                        vertical-alignment: center;
                                        text: SettingsBackend.ai-test-status;
                                        wrap: word-wrap;
                                        style: AppStore.theme.typography.caption;
                                        foreground: SettingsBackend.ai-test-ok
                                            ? AppStore.theme.accent.primary
                                            : #FF6B6B;
                                    }
                                }
                            }
                        }

                        // --- Appearance -----------------------------------
                        if root.section == 1: VerticalLayout {
                            spacing: AppStore.theme.metrics.spacing.md;

                            PaneTitle {
                                text: "Appearance";
                            }
                            Hint {
                                text: "Pick the editor theme. Applies instantly.";
                            }

                            FieldRow {
                                label: "Theme";
                                CutlassDropdown {
                                    current: root.theme-names[AppStore.theme-id];
                                    items: root.theme-names;
                                    selected(value) => {
                                        AppStore.theme-id =
                                            value == root.theme-names[0] ? 0
                                            : value == root.theme-names[1] ? 1
                                            : 2;
                                    }
                                }
                            }

                            // Temporary demo host for `CutlassColorPicker`
                            // (panel only — no consumer swap yet).
                            Rectangle {
                                height: 1px;
                                background: AppStore.theme.surface.divider;
                            }

                            CutlassText {
                                text: "Color picker (preview)";
                                style: AppStore.theme.typography.heading-sm;
                                foreground: AppStore.theme.text.primary;
                            }

                            Hint {
                                text: "Exercise the new picker here. Existing color wells still use the 24-swatch popup.";
                            }

                            ColorPickerDemo { }
                        }

                        // --- Storage & cache ------------------------------
                        if root.section == 2: VerticalLayout {
                            spacing: AppStore.theme.metrics.spacing.md;

                            PaneTitle {
                                text: "Storage & cache";
                            }
                            Hint {
                                text: "Caches are working data. Project drafts remain in their original locations, and downloaded source files still used by any project are protected from clearing and quota eviction.";
                            }
                            Hint {
                                text: "These paths come from the same cache registry the assistant uses. Enabled cache clears take effect immediately and cannot be undone; Cutlass recreates or downloads those contents when needed.";
                            }

                            FieldRow {
                                label: "Cache root";
                                CutlassLineInput {
                                    text: SettingsBackend.storage-root;
                                    placeholder-text: "Default Cutlass cache location";
                                    accessibility-label: "Current cache root";
                                    read-only: true;
                                    mono: true;
                                }
                                SubtleButton {
                                    label: SettingsBackend.cache-busy-id == ""
                                        ? "Choose…"
                                        : "Working…";
                                    enabled: SettingsBackend.storage-root-relocation-enabled
                                        && !SettingsBackend.cache-loading
                                        && SettingsBackend.cache-busy-id == "";
                                    clicked => {
                                        SettingsBackend.choose-storage-root();
                                    }
                                }
                            }
                            if !SettingsBackend.storage-root-relocation-enabled: Hint {
                                text: "Per-cache Move is available. Changing the default cache root is not available yet.";
                            }

                            FieldRow {
                                label: "Download quota";
                                CutlassLineInput {
                                    width: 112px;
                                    horizontal-stretch: 0;
                                    text <=> SettingsBackend.download-quota-mib;
                                    placeholder-text: "2048";
                                    accessibility-label: "Download cache quota in MiB";
                                    enabled: SettingsBackend.cache-busy-id == "";
                                    mono: true;
                                }
                                CutlassText {
                                    text: "MiB";
                                    vertical-alignment: center;
                                    style: AppStore.theme.typography.label;
                                    foreground: AppStore.theme.text.secondary;
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                }
                            }

                            Rectangle {
                                height: 1px;
                                background: AppStore.theme.surface.divider;
                            }

                            HorizontalLayout {
                                spacing: AppStore.theme.metrics.spacing.md;

                                CutlassText {
                                    horizontal-stretch: 1;
                                    text: "Caches";
                                    vertical-alignment: center;
                                    style: AppStore.theme.typography.heading-sm;
                                }
                                SubtleButton {
                                    label: SettingsBackend.cache-loading
                                        ? "Refreshing…"
                                        : "Refresh";
                                    enabled: !SettingsBackend.cache-loading
                                        && SettingsBackend.cache-busy-id == "";
                                    clicked => {
                                        SettingsBackend.refresh-caches();
                                    }
                                }
                            }

                            if SettingsBackend.cache-loading: Hint {
                                text: "Measuring cache usage…";
                            }

                            if SettingsBackend.cache-status != "": CutlassText {
                                text: SettingsBackend.cache-status;
                                wrap: word-wrap;
                                style: AppStore.theme.typography.caption;
                                foreground: AppStore.theme.accent.primary;
                            }

                            if SettingsBackend.cache-error != "": CutlassText {
                                text: SettingsBackend.cache-error;
                                wrap: word-wrap;
                                style: AppStore.theme.typography.caption;
                                foreground: #FF6B6B;
                            }

                            if !SettingsBackend.cache-loading
                                && SettingsBackend.cache-rows.length == 0
                                && SettingsBackend.cache-error == "": Hint {
                                text: "No cache usage is available yet.";
                            }

                            for cache in SettingsBackend.cache-rows: CacheUsageCard {
                                cache: cache;
                            }
                        }

                    }
                }
            }

            if SettingsBackend.save-error != "": CutlassText {
                text: SettingsBackend.save-error;
                wrap: word-wrap;
                style: AppStore.theme.typography.caption;
                foreground: #FF6B6B;
            }

            // --- footer ---------------------------------------------------
            HorizontalLayout {
                spacing: AppStore.theme.metrics.spacing.md;

                CutlassText {
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                    text: SettingsBackend.config-path;
                    mono: true;
                    overflow: elide;
                    style: AppStore.theme.typography.caption;
                    foreground: AppStore.theme.text.muted;
                }

                SubtleButton {
                    label: "Reveal config";
                    clicked => {
                        SettingsBackend.reveal-config();
                    }
                }

                AccentButton {
                    label: "Done";
                    clicked => {
                        root.close();
                    }
                }
            }
        }
    }
}
