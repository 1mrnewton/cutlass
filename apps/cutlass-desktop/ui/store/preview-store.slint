import { PreviewDragResolution } from "../lib/preview-backend.slint";

export global PreviewStore {
    in-out property <image> frame;

    // Docked preview viewport state. This is UI-only: it changes how the
    // composited frame is inspected, not the project canvas or clip transforms.
    in-out property <float> viewport-zoom: 1.0;
    in-out property <length> viewport-pan-x: 0px;
    in-out property <length> viewport-pan-y: 0px;

    // The preview area's on-screen size (logical px), reported by whichever
    // preview surface is live (docked panel or fullscreen). The engine worker
    // fits every render inside it so scrubbing pays for view-sized pixels
    // instead of the full canvas.
    callback viewport-changed(width: length, height: length);

    // Selected motion-path keyframe tick (absolute sequence tick), or -1
    // when none. Drives diamond accent + tangent handles.
    in-out property <int> motion-path-selected-tick: -1;
    // Live motion-path edit (0=idle, 1=move kf, 2=out tangent, 3=in tangent).
    in-out property <int> motion-path-edit-mode: 0;
    in-out property <int> motion-path-edit-tick: -1;
    in-out property <float> motion-path-edit-x: 0;
    in-out property <float> motion-path-edit-y: 0;
    // Sibling tangent (canvas fractions) captured at press for non-mirror
    // commits so dragging one handle doesn't wipe the other.
    in-out property <float> motion-path-edit-out-x: 0;
    in-out property <float> motion-path-edit-out-y: 0;
    in-out property <float> motion-path-edit-in-x: 0;
    in-out property <float> motion-path-edit-in-y: 0;
    // Mirrored tangent handles (default on). Alt is already pan, so this is
    // a toggle rather than a modifier.
    in-out property <bool> motion-path-mirror: true;

    // Live mask gizmo / inspector ParamOverride. When `mask-live-active` the
    // mask-gizmo callback uses these instead of playhead samples so handles
    // track mid-drag (projection stays frozen until commit).
    in-out property <bool> mask-live-active: false;
    in-out property <float> mask-live-center-x: 0;
    in-out property <float> mask-live-center-y: 0;
    in-out property <float> mask-live-size-w: 1;
    in-out property <float> mask-live-size-h: 1;
    in-out property <float> mask-live-rotation: 0;
    in-out property <float> mask-live-feather: 0;
    in-out property <float> mask-live-roundness: 0;
    // Active mask-handle drag id (0=idle; see MaskGizmo hit ids).
    in-out property <int> mask-drag-handle: 0;

    // Live transform gesture (preview roadmap Phases 3–5): the uncommitted
    // resolution of whatever gesture is in flight — a preview move/scale/
    // rotate drag or an inspector slider — mirrored UI-wide. The projection
    // stays frozen at committed values during a gesture by design (the live
    // value is a worker-side render override), so the selection box and the
    // inspector's numbers read this instead to follow mid-gesture.
    in-out property <bool> gesture-active: false;
    // A transform commit was sent while the projection still contains the
    // press-time values. Keep the live gesture visible until the next
    // projection publish swaps in the committed transform.
    in-out property <bool> gesture-commit-pending: false;
    in-out property <string> gesture-clip;
    in-out property <PreviewDragResolution> gesture;

    // Zero-drift transform gesture: partitioned frames rendered once at press.
    in-out property <image> gesture-frame-below;
    in-out property <image> gesture-frame-sprite;
    in-out property <image> gesture-frame-above;
    in-out property <bool> gesture-sprite-ready: false;
    in-out property <bool> gesture-has-above: false;
}
