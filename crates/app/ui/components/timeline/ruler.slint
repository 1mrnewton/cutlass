
import { TimelineState } from "./state.slint";

// Virtualized timeline ruler.
//
// The widget itself is always exactly the visible width — it does not scroll.
// On every frame we compute the first tick index visible at the current
// `scroll-x` and render `tick-count` ticks anchored to global timeline
// indices. Each tick's screen x is `global-idx * minor-spacing - scroll-x`,
// so labels stay correct while geometry stays bounded by viewport width.
export component Ruler inherits Rectangle {
    height: 24px;

    clip: true;

    property <length> scroll-x: TimelineState.scroll-x;
    property <length> minor-spacing: TimelineState.minor-spacing;
    property <int> major-every: TimelineState.major-every;

    property <int> first-tick: floor(scroll-x / minor-spacing);
    property <int> tick-count: ceil(self.width / minor-spacing) + 2;

    for idx in tick-count: Rectangle {
        property <int> global-idx: first-tick + idx;
        property <bool> major: mod(global-idx, major-every) == 0;
        x: global-idx * minor-spacing - scroll-x;
        y: 2px;
        width: major ? 1.2px : 1px;
        height: major ? 12px : 6px;
        background: major ? #5b5b5b : #464646;
    }

    for idx in tick-count: Text {
        property <int> global-idx: first-tick + idx;
        property <int> major-idx: global-idx / major-every;

        // Frame-mode: tick position is an exact frame index, time derived from it.
        property <int> frame-tick-total: major-idx * TimelineState.frames-per-major;
        property <float> frame-tick-seconds: frame-tick-total / TimelineState.fps;
        // Time-mode: tick position is an exact seconds value.
        property <float> sec-tick-seconds: major-idx * TimelineState.sec-per-major;

        property <float> tick-seconds: TimelineState.frame-mode
            ? frame-tick-seconds
            : sec-tick-seconds;

        property <int> total-sec: floor(tick-seconds);
        property <int> hours: floor(total-sec / 3600);
        property <int> minutes: mod(floor(total-sec / 60), 60);
        property <int> seconds: mod(total-sec, 60);
        property <int> tenths: floor((tick-seconds - total-sec) * 10);
        // Frames-within-second, using SMPTE-rounded fps (non-drop-frame).
        property <int> frames: mod(frame-tick-total, TimelineState.fps-int);

        visible: mod(global-idx, major-every) == 0;
        x: global-idx * minor-spacing - scroll-x + 5px;
        y: 3.5px;
        // Format depends on mode:
        //   time mode  : M:SS              (H:MM:SS past the hour; .t tenths when sec/major < 1)
        //   frame mode : M:SS:FF           (H:MM:SS:FF past the hour) — SMPTE-style, frames last
        text: TimelineState.frame-mode
            ? (hours > 0
                  ? (minutes < 10 ? "\{hours}:0\{minutes}:" : "\{hours}:\{minutes}:")
                  : "\{minutes}:")
              + (seconds < 10 ? "0\{seconds}:" : "\{seconds}:")
              + (frames < 10 ? "0\{frames}" : "\{frames}")
            : (hours > 0
                  ? (minutes < 10 ? "\{hours}:0\{minutes}:" : "\{hours}:\{minutes}:")
                  : "\{minutes}:")
              + (seconds < 10 ? "0\{seconds}" : "\{seconds}")
              + (TimelineState.sec-per-major < 1.0 ? ".\{tenths}" : "");
        color: #5b5b5b;
        font-size: 9px;
        font-weight: 700;
    }

    ta := TouchArea {
        width: 100%;
        height: 100%;

        property <length> drag-start-playhead-x;
        property <length> drag-origin-root-x;

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                let timeline-x = self.pressed-x + TimelineState.scroll-x;
                TimelineState.playhead-x = max(0px, min(TimelineState.viewport-width, timeline-x));
                self.drag-start-playhead-x = TimelineState.playhead-x;
                self.drag-origin-root-x = self.absolute-position.x + self.pressed-x;
            }
        }

        moved() => {
            if (!self.pressed) {
                return;
            }
            let drag-distance = self.drag-start-playhead-x + self.absolute-position.x + self.mouse-x - self.drag-origin-root-x;
            TimelineState.playhead-x = max(0px, min(TimelineState.viewport-width, drag-distance));
        }
    }
}
